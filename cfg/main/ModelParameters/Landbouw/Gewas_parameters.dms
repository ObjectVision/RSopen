container per_Gewas
{
	container Dairy
	{
		container Gras          := Gras_met_herinzaai;
		container Gras_maai     := Gras_zonder_herinzaai;
		container Gras_beweiden := Gras_met_herinzaai;
		container Mais          := Snijmais;
		
		container Gras_zonder_herinzaai 
		{
			parameter<Eur_Ha_jaarlijks> Production_costs               := 774[Eur_Ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			parameter<Ratio>            Rotation_BodemK_kleiig         := 0.801[Ratio]; //0.801
			parameter<Ratio>            Rotation_BodemK_zandig         := 0.630[Ratio]; //0.630
			parameter<Eur_ton>          Feeding_costs                  := 16[Eur_ton], Descr = "from LUS_AgriVali2011";
		}
		
		container Gras_met_herinzaai 
		{
			parameter<Eur_Ha_jaarlijks> Production_costs               := 774[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig         := 0.89[Ratio], Descr = "0 because low impact? @BART?, old value (.89) from Pinto & Diogo (2018) Agricultural land systems: Explaining and simulating agricultural landuse patterns. Chapter 3. Table 3.3"; //0.89
			parameter<Ratio>            Rotation_BodemK_zandig         := 0.70[Ratio], Descr = "0 because low impact? @BART?, old value (.70) from Pinto & Diogo (2018) Agricultural land systems: Explaining and simulating agricultural landuse patterns. Chapter 3. Table 3.3"; //0.70
			parameter<Eur_ton>          Feeding_costs                  := 16[Eur_ton], Descr = "feeding costs per dry matter ton, from LUS_AgriVali2011";
		}
		
		container Snijmais 
		{
			parameter<Eur_Ha_jaarlijks> Production_costs               := 774[Eur_Ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			parameter<Ratio>            Rotation_BodemK_kleiig         := 0.11[Ratio], Descr = "0 because low impact? @BART?, old value (.11) from Pinto & Diogo (2018) Agricultural land systems: Explaining and simulating agricultural landuse patterns. Chapter 3. Table 3.3"; //0.11
			parameter<Ratio>            Rotation_BodemK_zandig         := 0.30[Ratio], Descr = "0 because low impact? @BART?, old value (.30) from Pinto & Diogo (2018) Agricultural land systems: Explaining and simulating agricultural landuse patterns. Chapter 3. Table 3.3"; //0.30
			parameter<Eur_Ha_jaarlijks> Production_costs_BodemK_kleiig := 1491.3[Eur_Ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			parameter<Eur_Ha_jaarlijks> Production_costs_BodemK_zandig := 1504.1[Eur_Ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			parameter<Eur_ton>          Feeding_costs                  := 50[Eur_ton], Descr = "from LUS_AgriVali2011";
			
			parameter<Ratio>            DM_content                     := 0.35[Ratio]; // dry matter content	 // uitgangspunten normen bedrijfsbegroting melkveehouderij, 5 - 06 - 2014, in LUS_AgriVali2011=0.33
			parameter<Eur_ton>          Price_fresh_ton                := 60[Eur_ton]; // in LUS_AgriVali2011==42.2  // uitgangspunten normen bedrijfsbegroting melkveehouderij, 5 - 06 - 2014
			parameter<Eur_ton>          Price_DM_ton                   := Price_fresh_ton / DM_content;
			
			parameter<ton_ha_jaarlijks> DM_yield_BodemK_kleiig         := 15.3[ton_ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			parameter<ton_ha_jaarlijks> DM_yield_BodemK_zandig         := 13.0[ton_ha_jaarlijks], Descr = "from LUS_AgriVali2011";
			
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                    := 0[Eur_Ha_jaarlijks], Descr = "from LUS_AgriVali2011"; 
		}
		
		parameter<Bool>             TotalFeedExo                 := TRUE;
		parameter<Eur_ton>          MilkPrice                    := 400[Eur_ton], Descr = "https://agrimatie.nl/ThemaResultaat.aspx?subpubid=2232&themaid=2263&indicatorid=2068";
		parameter<Eur_ton>          Holding_costs                := 157.1[Eur_ton], Descr = "from LUS_AgriVali2011"; 
		parameter<Eur_ton>          Manure_revenue               := -30[Eur_ton], Descr = "https://www.mestportaal.nl/2024/kosten-mestafzet-blijven-hoog/";
		
		parameter<Ratio>            feed_composition_share_grass         := 0.75[Ratio]; //in LUS_AgriVali2011=0.6
		parameter<Ratio>            feed_composition_share_mais          := 0.25[Ratio]; //in LUS_AgriVali2011=0.2
		parameter<Ratio>            feed_composition_share_concentrates  := 0.00[Ratio]; //in LUS_AgriVali2011=0.2
		
		container Feed_concentrates 
		{
			parameter<Ratio>            DM_content                     := 0.89[Ratio], Descr = "from LUS_AgriVali2011";
			parameter<Eur_ton>          Price_fresh_ton                := 215[Eur_ton]; // uitgangspunten normen bedrijfsbegroting melkveehouderij, 5 - 06 - 2014. in LUS_AgriVali2011==186
			parameter<Eur_ton>          Price_DM_ton                   := Price_fresh_ton / DM_content;
			parameter<Eur_ton>          Feeding_costs                  := 20[Eur_ton], Descr = "from LUS_AgriVali2011"; 
		}
	}

	container Rietteelt
	{
		container Riet
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 10[ton_ha_jaarlijks];    // Kuhlman et al. 2013
			parameter<Eur_ton>          MarketPrice                   := 120[Eur_ton];            // Kuhlman et al. 2013
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 500[Eur_Ha_jaarlijks];   // Kuhlman et al. 2013
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 500[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];    // Geen GLB voor riet
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];              // Meerjarige teelt
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
		container Lisdodde
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 15[ton_ha_jaarlijks];    // Geschat, WUR
			parameter<Eur_ton>          MarketPrice                   := 150[Eur_ton];            // Geschat
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 600[Eur_Ha_jaarlijks];   // Geschat
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 600[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
	}

	container Aardappelen
	{
		container Aardappelen  
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 43[ton_ha_jaarlijks];    // BIJ12-2024 gewogen gem.
			parameter<Eur_ton>          MarketPrice                   := 190[Eur_ton];            // BIJ12-2024 gewogen gem.
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 3300[Eur_Ha_jaarlijks]; // KWIN-DUMMY ~40% van bruto
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 3000[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks]; // RVO-GLB 2024
			parameter<Ratio>            Rotation_BodemK_kleiig        := 0.27[Ratio];             // Diogo-2015
			parameter<Ratio>            Rotation_BodemK_zandig        := 0.48[Ratio];
		}
		
		// container Consumptieaardappelen
		// {
			// parameter<ton_ha_jaarlijks> MaxYield                      := 49.5[ton_ha_jaarlijks]; // BIJ12-2024 klei IJsselmeerp.
			// parameter<Eur_ton>          MarketPrice                   := 170[Eur_ton];          // BIJ12-2024
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 3400[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 3400[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			// parameter<Ratio>            Rotation_BodemK_kleiig        := 0.16[Ratio];            // Diogo-2015 15.6%
			// parameter<Ratio>            Rotation_BodemK_zandig        := 0.15[Ratio];
		// }
		// container Pootaardappelen
		// {
			// parameter<ton_ha_jaarlijks> MaxYield                      := 36.0[ton_ha_jaarlijks]; // BIJ12-2024 klei-gem.
			// parameter<Eur_ton>          MarketPrice                   := 310[Eur_ton];          // BIJ12-2024
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 4500[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 4500[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			// parameter<Ratio>            Rotation_BodemK_kleiig        := 0.12[Ratio];            // Diogo-2015 11.9%
			// parameter<Ratio>            Rotation_BodemK_zandig        := 0.04[Ratio];
		// }
		// container Zetmeelaardappelen
		// {
			// parameter<ton_ha_jaarlijks> MaxYield                      := 40.0[ton_ha_jaarlijks]; // BIJ12-2024
			// parameter<Eur_ton>          MarketPrice                   := 100[Eur_ton];          // BIJ12-2024
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 1600[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 1600[Eur_Ha_jaarlijks];
			// parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			// parameter<Ratio>            Rotation_BodemK_kleiig        := 0.00[Ratio];
			// parameter<Ratio>            Rotation_BodemK_zandig        := 0.29[Ratio];            // Diogo-2015 28.8%
		// }
	}

	container Bieten
	{
		container Bieten
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 89[ton_ha_jaarlijks];    // BIJ12-2024 klei-gem.
			parameter<Eur_ton>          MarketPrice                   := 45[Eur_ton];             // BIJ12-2024
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 1600[Eur_Ha_jaarlijks]; // KWIN-DUMMY
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 1450[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 0.15[Ratio];             // Diogo-2015
			parameter<Ratio>            Rotation_BodemK_zandig        := 0.21[Ratio];
		}
	}

	container Granen
	{
		container Granen
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 9[ton_ha_jaarlijks];     // BIJ12-2024 wintertarwe-dominant
			parameter<Eur_ton>          MarketPrice                   := 225[Eur_ton];            // BIJ12-2024
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 800[Eur_Ha_jaarlijks];  // KWIN-DUMMY
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 750[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 0.49[Ratio];             // Diogo-2015
			parameter<Ratio>            Rotation_BodemK_zandig        := 0.29[Ratio];
		}
	}

	container Boomgaard
	{
		container Boomgaard
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 35[ton_ha_jaarlijks];    // CBS/BIJ12 schatting
			parameter<Eur_ton>          MarketPrice                   := 400[Eur_ton];            // BIJ12 schatting
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 6900[Eur_Ha_jaarlijks]; // Diogo-2015 Table 5
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 6900[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 260[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];              // Meerjarig
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
	}

	container Cranberry
	{
		container Cranberry
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 15[ton_ha_jaarlijks];
			parameter<Eur_ton>          MarketPrice                   := 800[Eur_ton];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 4800[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 4800[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
	}

	container Moerasbomen
	{
		container Moerasbomen
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 8[ton_ha_jaarlijks];
			parameter<Eur_ton>          MarketPrice                   := 80[Eur_ton];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 300[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 300[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
	}

	container Rijst
	{
		container Rijst
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 5[ton_ha_jaarlijks];
			parameter<Eur_ton>          MarketPrice                   := 500[Eur_ton];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 1000[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 1000[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 1.0[Ratio];
			parameter<Ratio>            Rotation_BodemK_zandig        := 1.0[Ratio];
		}
	}

	container Yacon
	{
		container Yacon
		{
			parameter<ton_ha_jaarlijks> MaxYield                      := 30[ton_ha_jaarlijks];
			parameter<Eur_ton>          MarketPrice                   := 300[Eur_ton];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_kleiig := 3600[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> ProductionCosts_BodemK_zandig := 3600[Eur_Ha_jaarlijks];
			parameter<Eur_Ha_jaarlijks> CAP_subsidy                   := 0[Eur_Ha_jaarlijks];
			parameter<Ratio>            Rotation_BodemK_kleiig        := 0.25[Ratio];
			parameter<Ratio>            Rotation_BodemK_zandig        := 0.25[Ratio];
		}
	}
}