container Landbouw : using = "Classifications/Actor"
{
	// parameter<BoervariantK>     Boervariant                               := BoervariantK/V/IntermediateBoer, Descr = "Kies hier de boervariant die in het model wordt gebruikt. RationeleBoer, IntermediateBoer, ConservatieveBoer";
	
	// Manual ConstGrowthMinMax UndefinedMax
	parameter<String>           ClaimVariant                              := 'Manual', Descr = "Kies hier de manier waarop de minimale en maximale claims voor landbouw worden bepaald. Manual: handmatig in te vullen, ConstGrowthMinMax: op basis van een constante groei tov het vorige zichtjaar, UndefinedMax: minimale claims worden handmatig ingevuld, maximale claims zijn onbegrensd (undefined)";
	parameter<Bool>             UseYieldReductionFromDeltaresIfAvailable  := TRUE, Descr = "If available list is configured here: /Classifications/Landbouw/GewasSoortYR/HeeftDeltares_YR_map";
	parameter<Bool>             UseYieldReductionFromDiogoIfAvailable     := TRUE, Descr = "If available list is configured here: /Classifications/Landbouw/GewasSoortYR/HeeftDiogo_YR_map";
	parameter<Float32>          Landbouw_Claim_Growth                     := 0.20f, Descr = "factor waarmee de max claims voor Landbouw worden bepaald tov prev zichtjaar";
	parameter<jaarlijks>        Rentevoet                                 := 0.055[jaarlijks], Descr = "Rentevoet die wordt gebruikt voor de contante waarde berekeningen";
	parameter<jaarlijks>        Rentevoet_RationeleBoer                   := Rentevoet;
	parameter<jaarlijks>        Rentevoet_IntermediateBoer                := 0.080[jaarlijks]; //TODO: checken met Marnix/Femke
	parameter<jaarlijks>        Rentevoet_ConservatieveBoer               := 0.16[jaarlijks]; //TODO: checken met Marnix/Femke
	parameter<Float32>          ConversionCostPremium_RationeleBoer       := 0.00f; //TODO: checken met Marnix/Femke
	parameter<Float32>          ConversionCostPremium_IntermediateBoer    := 0.20f; //TODO: checken met Marnix/Femke
	parameter<Float32>          ConversionCostPremium_ConservatieveBoer   := 1.00f; //TODO: checken met Marnix/Femke
	parameter<jaar>             afschrijvingsperiode                      := 20[jaar], Descr = "Afschrijvingsperiode voor investeringen in de landbouw (bijv. gewasverandering)";
	parameter<Float32>          YieldReduction_NoData                     := -99999f, Descr = "Waarde die aangeeft dat er geen data is voor opbrengstderving";
	parameter<Float32>          Verzilt_Areaal_Fractie                    := 0.40f, Descr = "xx% van het oppervlak van risico's 2-4 is in de toekomst niet geschikt voor de gewassen: Appelbomen, consumptieaardappelen, laanbomen, tulpen, zaaiuien en zetmeelaardappelen. Deze plekken worden random gekozen"; 
	parameter<Float32>          Verzilt_OpbrengstDerving                  := 1f, Descr = "Mate van effect van verzilting op opbrengsten derving van de gewassen die daardoor worden aangetast."; 
	parameter<Float32>          Verzilt_OpbrengstDerving_Y2030            := 0f, Descr = "Mate van effect van verzilting op opbrengsten derving van de gewassen die daardoor worden aangetast."; 
	parameter<meter>            SuitWegingMaxAfstandN2000                 := 300[meter], Descr = "Maximale afstand tot N2000 gebied waarbij de geschiktheid voor landbouw nog wordt beïnvloed door de nabijheid van N2000 gebied. Bij grotere afstanden is er geen invloed meer.";
	parameter<Float32>          SuitWegingFactorN2000                     := 0.2f, Descr = "Factor waarmee de geschiktheid voor landbouw wordt vermenigvuldigd als de afstand tot N2000 gebied 0 meter is. Bij grotere afstanden neemt de invloed af tot 0 bij de maximale afstand.";
	parameter<kg_ha_jaarlijks>  CO2_Uitstoot_StedelijkGebruik             := 0[kg_ha_jaarlijks], Descr = "CO2 uitstoot door omzetting van landbouwgrond naar stedelijk gebruik";
	parameter<kg_ha_jaarlijks>  CO2_Uitstoot_Water                        := 0[kg_ha_jaarlijks], Descr = "CO2 uitstoot door omzetting van landbouwgrond naar water";
	
	parameter<String>           VerziltingsScenario                       := 'Stoom2050', Descr = "Welk verziltingsscenario wordt toegepast. Opties: Stoom2050, Stoom2100";
	
	parameter<Eur_ton> CO2_prijs_minimum: [30], Descr = "Minimale CO2 prijs (in Eur/ton) die wordt gebruikt in de berekening van de contante waarde van CO2 reductie door landbouwgrond om te zetten naar andere functies.";
	parameter<Eur_ton> CO2_prijs_maximum: [80], Descr = "Maximale CO2 prijs (in Eur/ton) die wordt gebruikt in de berekening van de contante waarde van CO2 reductie door landbouwgrond om te zetten naar andere functies.";
	
	attribute<Float32> CO2_Reductie (RegioIndelingen/Provincie) := switch(
		 case(id(Provincie) == Provincie/v/groningen, 0.06f)
		,case(id(Provincie) == Provincie/v/friesland, 0.45f)
		,case(id(Provincie) == Provincie/v/overijssel, 0.10f)
		,case(id(Provincie) == Provincie/v/utrecht, 0.09f)
		,case(id(Provincie) == Provincie/v/noord_holland, 0.09f)
		,case(id(Provincie) == Provincie/v/zuid_holland, 0.21f)
		,null_f
	), Descr = "Indicatieve CO2 (equivalente) reductieopgave per Provincie (in %, totale opgave is 1Mton/jaar t.o.v. 1990). Uit mail DGWB, d.d. 8-5-2025";
	
	container Aanlegkosten_waterinfiltratiesystemen
	: Descr = "actieve (pompgestuurde) systemen. Indicatief, uit mail DGWB, d.d. 8-5-2025", URL = "https://loketveenweideboeren.nl/aanleg-waterinfiltratiesysteem/"
	{
		parameter<Eur_ha> passief_laag := 4000[Eur_ha];
		parameter<Eur_ha> passief_hoog := 5000[Eur_ha];
		parameter<Eur_ha> actief_laag  := 6000[Eur_ha];
		parameter<Eur_ha> actief_hoog  := 7500[Eur_ha];
	}
	
	container claims_ggvee_minfractie // ggvee wordt voor de helft vervangen door exotoische gewassen
	: Descr = "Claims waarbij minimaal een bepaald percentage ggvee overblijft"
	{
		parameter<String> min_fractie_gg_vee := '0.90f', Descr = "Minimum percentage ggvee dat overblijft na claims";
		
		container MinClaims_manual
		: Descr = "Handmatig in te vullen minimale claims per gewas"
		{
			parameter<String>   Rietteelt         := '(StartYear_minusNietBeschikbaar/gg_vee_extensief + StartYear_minusNietBeschikbaar/gg_vee + StartYear_minusNietBeschikbaar/gg_vee_intensief) * (1f - '+min_fractie_gg_vee+') * 0.35f', Descr = "Rietteelt wordt voor 35% van de claimreductie uit gg_vee gebruikt";
			// parameter<String>   Akkerbouw         := 'StartYear_minusNietBeschikbaar/Akkerbouw * 0.8f', Descr = "Akkerbouw wordt voor 80% van de claim gebruikt. extra afname om genoeg plaats te garanderen door afronding etc.";
			parameter<String>   Aardappelen       := 'StartYear_minusNietBeschikbaar/Aardappelen * 0.8f', Descr = "Akkerbouw wordt voor 80% van de claim gebruikt. extra afname om genoeg plaats te garanderen door afronding etc.";
			parameter<String>   Bieten            := 'StartYear_minusNietBeschikbaar/Bieten * 0.8f', Descr = "Akkerbouw wordt voor 80% van de claim gebruikt. extra afname om genoeg plaats te garanderen door afronding etc.";
			parameter<String>   Granen            := 'StartYear_minusNietBeschikbaar/Granen * 0.8f', Descr = "Akkerbouw wordt voor 80% van de claim gebruikt. extra afname om genoeg plaats te garanderen door afronding etc.";
			parameter<String>   Cranberry         := '(StartYear_minusNietBeschikbaar/gg_vee_extensief + StartYear_minusNietBeschikbaar/gg_vee + StartYear_minusNietBeschikbaar/gg_vee_intensief) * (1f - '+min_fractie_gg_vee+') * 0.1f', Descr = "Cranberry wordt voor 10% van de claimreductie uit gg_vee gebruikt";
			parameter<String>   Boomgaard         := 'StartYear_minusNietBeschikbaar/Boomgaard', Descr = "Boomgaard wordt voor 100% van de claim gebruikt";
			parameter<String>   Moerasbomen       := '(StartYear_minusNietBeschikbaar/gg_vee_extensief + StartYear_minusNietBeschikbaar/gg_vee + StartYear_minusNietBeschikbaar/gg_vee_intensief) * (1f - '+min_fractie_gg_vee+') * 0.35f', Descr = "Moerasbomen wordt voor 35% van de claimreductie uit gg_vee gebruikt";
			parameter<String>   Rijst             := '(StartYear_minusNietBeschikbaar/gg_vee_extensief + StartYear_minusNietBeschikbaar/gg_vee + StartYear_minusNietBeschikbaar/gg_vee_intensief) * (1f - '+min_fractie_gg_vee+') * 0.1f', Descr = "Rijst wordt voor 10% van de claimreductie uit gg_vee gebruikt";
			parameter<String>   Yacon             := '(StartYear_minusNietBeschikbaar/gg_vee_extensief + StartYear_minusNietBeschikbaar/gg_vee + StartYear_minusNietBeschikbaar/gg_vee_intensief) * (1f - '+min_fractie_gg_vee+') * 0.1f', Descr = "Yacon wordt voor 10% van de claimreductie uit gg_vee gebruikt";
			parameter<String>   gg_vee_extensief  := 'StartYear_minusNietBeschikbaar/gg_vee_extensief * '+min_fractie_gg_vee+'', Descr = "Minimaal het opgegeven percentage gg_vee blijft over";
			parameter<String>   gg_vee            := 'StartYear_minusNietBeschikbaar/gg_vee           * '+min_fractie_gg_vee+'', Descr = "Minimaal het opgegeven percentage gg_vee blijft over";
			parameter<String>   gg_vee_intensief  := 'StartYear_minusNietBeschikbaar/gg_vee_intensief * '+min_fractie_gg_vee+'', Descr = "Minimaal het opgegeven percentage gg_vee blijft over";
			// parameter<String>   NonLandbouw       := 'const(0[ha], RegioUnit, ha)';
		}
		
		container MaxClaims_manual
		: Descr = "Handmatig in te vullen maximale claims per gewas"
		{
			parameter<String>   Rietteelt         := 'const(null_f, RegioUnit, ha)';
			// parameter<String>   Akkerbouw         := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Aardappelen       := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Bieten            := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Granen            := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Cranberry         := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Boomgaard         := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Moerasbomen       := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Yacon             := 'const(null_f, RegioUnit, ha)';
			parameter<String>   Rijst             := 'const(null_f, RegioUnit, ha)';
			parameter<String>   gg_vee_extensief  := 'const(null_f, RegioUnit, ha)';
			parameter<String>   gg_vee            := 'const(null_f, RegioUnit, ha)';
			parameter<String>   gg_vee_intensief  := 'const(null_f, RegioUnit, ha)';
			// parameter<String>   NonLandbouw       := 'const(null_f, RegioUnit, ha)';
		}
	}
	
	container claims_conservatief
	: Descr = "Claims waarbij minimaal een bepaald percentage ggvee overblijft, conservatief"
	{
		parameter<String> min_fractie_gg_vee := '0.95f'; // minimum percentage ggvee dat overblijft
		
		container MinClaims_manual
		: Descr = "Handmatig in te vullen minimale claims per gewas"
		{
			parameter<String>   Rietteelt         := 'StartYear/Rietteelt * 0.95f';
			// parameter<String>   Akkerbouw         := 'StartYear/Akkerbouw * 0.95f';
			parameter<String>   Aardappelen       := 'StartYear/Aardappelen * 0.95f';
			parameter<String>   Bieten            := 'StartYear/Bieten * 0.95f';
			parameter<String>   Granen            := 'StartYear/Granen * 0.95f';
			parameter<String>   Cranberry         := 'StartYear/Cranberry * 0.95f';
			parameter<String>   Boomgaard         := 'StartYear/Boomgaard * 0.95f';
			parameter<String>   Moerasbomen       := 'StartYear/Moerasbomen * 0.95f';
			parameter<String>   Yacon             := 'StartYear/Yacon * 0.95f';
			parameter<String>   Rijst             := 'StartYear/Rijst * 0.95f';
			parameter<String>   gg_vee_extensief  := 'StartYear/gg_vee_extensief * '+min_fractie_gg_vee+'';
			parameter<String>   gg_vee            := 'StartYear/gg_vee           * '+min_fractie_gg_vee+'';
			parameter<String>   gg_vee_intensief  := 'StartYear/gg_vee_intensief * '+min_fractie_gg_vee+'';
		}
		
		container MaxClaims_manual
		: Descr = "Handmatig in te vullen maximale claims per gewas"
		{
			parameter<String>   Rietteelt         := 'StartYear/Rietteelt * 2.0f';
			parameter<String>   Akkerbouw         := 'StartYear/Akkerbouw * 1.05f';
			parameter<String>   Aardappelen       := 'StartYear/Aardappelen * 1.05f';
			parameter<String>   Bieten            := 'StartYear/Bieten * 1.05f';
			parameter<String>   Granen            := 'StartYear/Granen * 1.05f';
			parameter<String>   Cranberry         := 'StartYear/Rietteelt * 1.05f';
			parameter<String>   Boomgaard         := 'StartYear/Boomgaard * 1.05f';
			parameter<String>   Moerasbomen       := 'StartYear/Moerasbomen * 1.05f';
			parameter<String>   Yacon             := 'StartYear/Rietteelt * 1.05f';
			parameter<String>   Rijst             := 'StartYear/Rietteelt * 1.05f';
			parameter<String>   gg_vee_extensief  := 'const(null_f, RegioUnit, ha)';
			parameter<String>   gg_vee            := 'const(null_f, RegioUnit, ha)';
			parameter<String>   gg_vee_intensief  := 'const(null_f, RegioUnit, ha)';
		}
	}
	//"herkomst in rijen, bestemming in kolommen";
	unit<UInt8> Transitiekosten :=
		for_each_nedv(
			Classifications/Actor/LandbouwKlasses/name
			, replace(
				'union_data(Classifications/Actor/LandbouwKlasses, '+asList('Transitiekosten_src/'+Classifications/Actor/LandbouwKlasses/name+'__@Best@', ',')+')',
				'@Best@', Classifications/Actor/LandbouwKlasses/name)
			,Classifications/Actor/LandbouwKlasses
			, Eur_ha
		), Descr = "Transitiekosten matrix, in Eur/ha, per herkomst en bestemming. Herkomst en bestemming zijn de landbouwklassen. De transitiekosten worden gebruikt om de contante waarde van een gewasverandering te berekenen. De transitiekosten worden alleen in rekening gebracht als er daadwerkelijk een gewasverandering plaatsvindt (dus niet bij een claim op hetzelfde gewas). De transitiekosten worden per ha in rekening gebracht. De transitiekosten worden alleen in rekening gebracht als er daadwerkelijk een gewasverandering plaatsvindt (dus niet bij een claim op hetzelfde gewas). De transitiekosten worden per ha in rekening gebracht.";
	
	#include<Gewas_parameters.dms>
	
	container per_ModelType
	{
		container Akkerbouw //arable farming
		{
			parameter<Ratio>            Holding_costs_Ratio          := 0.208[Ratio], Descr = "from LUS_AgriVali2011";
			// parameter<Eur_Ha_jaarlijks> land_costs                   := 45525[Eur_Ha_jaarlijks], Descr = "If current ? 0 : value, from LUS_AgriVali2011";
		}
		
		container gg_vee_extensief
		{
			parameter<Ratio>            FCE                          := 1.00[Ratio], Descr = "Feed Conversion Efficiency";
			parameter<ton_ha_jaarlijks> MaxYieldGrass                := 6.419[ton_ha_jaarlijks];
			parameter<Ratio>            Perc_FeedDryMatter           := 0.73[Ratio];
			parameter<Eur_ton>          MilkPricePremium             := 30[Eur_ton];
		}
		
		container gg_vee
		{
			parameter<Ratio>            FCE                          := 1.10[Ratio], Descr = "Feed Conversion Efficiency";
			parameter<ton_ha_jaarlijks> MaxYieldGrass                := 9.816[ton_ha_jaarlijks];
			parameter<Ratio>            Perc_FeedDryMatter           := 0.70[Ratio];
			parameter<Eur_ton>          MilkPricePremium             := 0[Eur_ton];
		}
		
		container gg_vee_intensief
		{
			parameter<Ratio>            FCE                          := 1.20[Ratio], Descr = "Feed Conversion Efficiency";
			parameter<ton_ha_jaarlijks> MaxYieldGrass                := 11.164[ton_ha_jaarlijks];
			parameter<Ratio>            Perc_FeedDryMatter           := 0.68[Ratio];
			parameter<Eur_ton>          MilkPricePremium             := 0[Eur_ton];
		}
	}
	
	container Transitiekosten_src
	{
		container InvestmentCosts : Descr = "from Diogo (2015), table 5: investment costs"
		{
			parameter<Eur_ha> DairyFarming      :[14269];
			parameter<Eur_ha> ArableFarming     :[ 7257];
			parameter<Eur_ha> VegetableGrowing  :[14890];
			parameter<Eur_ha> FruitGrowing      :[35858];
			parameter<Eur_ha> FlowerGrowing     :[26254];
			parameter<Eur_ha> TreeNursery       :[35055];
		}
		
		// parameter<Eur_m2> Kosten_urbaan_afbraak              := 311.555209[Eur_m2], Descr = "from PeatyMeadows"; // @Jip deze is overbodig in deze cfg toch, omdat we eerder gealloceerde klassen zoals urbaan op slot zetten bij de alloc van later gealloc klassen zoals Landbouw
		// parameter<Eur_m2> Akkerbouw                          := InvestmentCosts/ArableFarming[Eur_m2];
		// parameter<Eur_m2> Default_min_transitiekosten        := 100[Eur_m2];
		
		// van riet naar...
		parameter<Eur_ha> Rietteelt__Rietteelt               := 0[Eur_ha];
		// parameter<Eur_ha> Rietteelt__Akkerbouw               := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Rietteelt__Aardappelen             := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Rietteelt__Bieten                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Rietteelt__Granen                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Rietteelt__Cranberry               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Rietteelt__Boomgaard               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Rietteelt__Moerasbomen             := InvestmentCosts/ArableFarming * 0.5f; // lijkt me niet zo duur
		parameter<Eur_ha> Rietteelt__Rijst                   := InvestmentCosts/FruitGrowing; // lijjkt me duur om in te richten
		parameter<Eur_ha> Rietteelt__Yacon                   := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Rietteelt__gg_vee_extensief        := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Rietteelt__gg_vee                  := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Rietteelt__gg_vee_intensief        := InvestmentCosts/DairyFarming;
		
		// van Akkerbouw naar...
		// parameter<Eur_ha> Akkerbouw__Rietteelt               := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Akkerbouw__Akkerbouw               := 0[Eur_ha];
		// parameter<Eur_ha> Akkerbouw__Cranberry               := InvestmentCosts/FruitGrowing;
		// parameter<Eur_ha> Akkerbouw__Boomgaard               := InvestmentCosts/FruitGrowing;
		// parameter<Eur_ha> Akkerbouw__Moerasbomen             := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Akkerbouw__Rijst                   := InvestmentCosts/FruitGrowing;
		// parameter<Eur_ha> Akkerbouw__Yacon                   := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Akkerbouw__gg_vee_extensief        := InvestmentCosts/DairyFarming;
		// parameter<Eur_ha> Akkerbouw__gg_vee                  := InvestmentCosts/DairyFarming;
		// parameter<Eur_ha> Akkerbouw__gg_vee_intensief        := InvestmentCosts/DairyFarming;
		
		parameter<Eur_ha> Aardappelen__Rietteelt               := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Aardappelen__Akkerbouw               := 0[Eur_ha];
		parameter<Eur_ha> Aardappelen__Aardappelen             := 0[Eur_ha];
		parameter<Eur_ha> Aardappelen__Bieten                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Aardappelen__Granen                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Aardappelen__Cranberry               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Aardappelen__Boomgaard               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Aardappelen__Moerasbomen             := InvestmentCosts/ArableFarming * 0.5f;
		parameter<Eur_ha> Aardappelen__Rijst                   := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Aardappelen__Yacon                   := InvestmentCosts/ArableFarming * 0.5f;
		parameter<Eur_ha> Aardappelen__gg_vee_extensief        := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Aardappelen__gg_vee                  := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Aardappelen__gg_vee_intensief        := InvestmentCosts/DairyFarming;
		
		parameter<Eur_ha> Bieten__Rietteelt               := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Bieten__Akkerbouw               := 0[Eur_ha];
		parameter<Eur_ha> Bieten__Aardappelen             := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Bieten__Bieten                  := 0[Eur_ha];
		parameter<Eur_ha> Bieten__Granen                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Bieten__Cranberry               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Bieten__Boomgaard               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Bieten__Moerasbomen             := InvestmentCosts/ArableFarming * 0.5f;
		parameter<Eur_ha> Bieten__Rijst                   := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Bieten__Yacon                   := InvestmentCosts/ArableFarming * 0.5f;
		parameter<Eur_ha> Bieten__gg_vee_extensief        := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Bieten__gg_vee                  := InvestmentCosts/DairyFarming;
		parameter<Eur_ha> Bieten__gg_vee_intensief        := InvestmentCosts/DairyFarming;
		
		parameter<Eur_ha> Granen__Rietteelt               := InvestmentCosts/ArableFarming * 0.5f;
		// parameter<Eur_ha> Granen__Akkerbouw               := 0[Eur_ha];
		parameter<Eur_ha> Granen__Aardappelen             := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Granen__Bieten                  := InvestmentCosts/ArableFarming;
		parameter<Eur_ha> Granen__Granen                  := 0[Eur_ha];
		parameter<Eur_ha> Granen__Cranberry               := InvestmentCosts/FruitGrowing;
		parameter<Eur_ha> Granen__Boomgaard               := InvestmentCosts/FruitGrowing;
