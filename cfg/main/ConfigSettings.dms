////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//
// Dit is RSOpen, de open source versie van het model RuimteScanner. Het scipt wordt uitgegeven onder GNU-GPL licentie.
//
// RSOpen is ontwikkeld door PBL Planbureau voor de Leefomgeving, i.s.m Object Vision en VU Vrije Universiteit Amsterdam.
// Opdrachtgever/ontwikkelaar PBL: Bas van Bemmel (Bas.vanBemmel@pbl.nl)
// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Dit bestand bevat de basispaden voor data-invoer en resultaatopslag.
// De parameters in 'Overridable' kunnen worden overschreven via:
//   1. Het GeoDMS GUI-menu: Tools > Options > Config Settings
//      Waarden die daar worden ingesteld overschrijven de defaults hieronder.
//   2. Omgevingsvariabelen of command-line parameters in batchmodus.
//
// %sourceDataDir% verwijst naar het pad dat is ingesteld in de GeoDMS-configuratie
// (standaard: de map die is opgegeven bij installatie of via GUI > Options).
//
// Paden:
//   RSo_DataDir    : hoofdmap voor alle RSopen-invoerdata
//   RSL_DataDir    : invoerdata voor de RSL-koppeling
//   RS_Lb_DataDir  : invoerdata voor de landbouwmodule
//   PrivDataDir    : niet-publiek beschikbare invoerdata (plancapaciteiten, etc.)
//   ResultatenDir  : uitvoermap voor alle resultaten en ontkoppelde tussenbestanden
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container ConfigSettings
{
	container Overridable
	{ 
		parameter<String> RSo_DataDir := '%sourceDataDir%/RuimteScanner/Ruimtescanner/SD/RSopen';
		parameter<String> RSL_DataDir := '%sourceDataDir%/RuimteScanner/Ruimtescanner/SD/RSL'; //zit alleen nog bij de bereikbaarheids inidicatoren.
		parameter<String> RS_Lb_DataDir := '%sourceDataDir%/RuimteScanner/Ruimtescanner/SD/RS_Landbouw';
		parameter<String> PrivDataDir   := '%sourceDataDir%/RSOpen_Priv';
		parameter<String> ResultatenDir := '%sourceDataDir%/RuimteScanner/Ruimtescanner/SD/Resultaten';
		parameter<String> BAG_DataDir   := 'C:/Users/JipClaassens/Objectvision/Object Vision - SourceData/BAG';
	}
}
