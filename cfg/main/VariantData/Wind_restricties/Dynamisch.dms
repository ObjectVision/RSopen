// Opdrachtgever/ontwikkelaar PBL: Bas van Bemmel (Bas.vanBemmel@pbl.nl)
// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Hier worden restrictisch bepaald voor het plaatsen van windturbines. In deze container de dynamisch
// veronderstelde elementen. Oftewel, de elementen die moeten worden geupdate na allocatie van eerdere sectoren.
// Sommige van deze elementen hier zijn slechts place holders, met een false domain (i.e. structuur wordt hier
// gemaakt, die in latere stappen wordt opgevraagd en geupdatet) 4. bestaande turbines --> afstand = 4 *
// rotordiameter 7. losse bebouwing geluid a. Woningen buiten Woonkernen Laadt via #include:
// beperkt_kwestbare_gebouwen, kwestbare_gebouwen.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container Dynamisch
: Descr = "Hier worden restrictisch bepaald voor het plaatsen van windturbines. In deze container de dynamisch veronderstelde elementen. Oftewel, de elementen die moeten worden geupdate na allocatie van eerdere sectoren. Sommige van deze elementen hier zijn slechts place holders, met een false domain (i.e. structuur wordt hier gemaakt, die in latere stappen wordt opgevraagd en geupdatet) "
{
	#include<beperkt_kwestbare_gebouwen.dms>
	#include<kwestbare_gebouwen.dms>
	
	unit<UInt32> Bestaande_turbines := SourceData/Energie/Wind/Veldsituatie/Punten
	, Descr = "4.  bestaande turbines --> afstand = 4 * rotordiameter"
	{
		attribute<rdc_meter> geometry               := SourceData/Energie/Wind/Veldsituatie/Punten/geometry;
		attribute<rdc_meter> geometry_buffer (poly) := bg_buffer_point(geometry, float64(ModelParameters/Wind/AantalKeerWerpafstandRestrictieHuidigeTurbines * CaseClassifications/WindTurbineType/RotorDiameter), 16b), Descr = "";
		attribute<Bool>      IsNietToegestaan_basis (AdminDomain)   := IsDefined(poly2grid(geometry_buffer, AdminDomain));
	
	}
	
	container losse_bebouwing_geluid
	: Descr = "7.  losse bebouwing geluid
				a. Woningen buiten Woonkernen"
	{
		attribute<Bool> IsNietToegestaan_basis (AdminDomain)   := const(FALSE, AdminDomain);
	}
	
	container Woonkernen
	: Descr = "14. Woonkernen -> afstand = 500 meter
					a. aaneengesloten Woningen binnen een woonkern"
	{
		attribute<Bool> IsNietToegestaan_basis (AdminDomain)   := const(FALSE, AdminDomain);
	}
}