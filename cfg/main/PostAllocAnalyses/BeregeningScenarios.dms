////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container BeregeningScenarios
{
	attribute<LU_ModelType> Grondgebruik_A_GeenBeregening                   (AdminDomain): StorageName = "='%LocalDataProjDir%/Indicatoren/Landgebruik/WLO_Hoog_BAU/RationeleBoer/A_GeenBeregening/Y2050/'+/ModelParameters/StudyArea+'.tif'", StorageType = "gdal.grid";
	attribute<LU_ModelType> Grondgebruik_B1_Beregening_allepercelen_ongelim (AdminDomain): StorageName = "='%LocalDataProjDir%/Indicatoren/Landgebruik/WLO_Hoog_BAU/RationeleBoer/B1_Beregening_allepercelen_ongelim/Y2050/'+/ModelParameters/StudyArea+'.tif'", StorageType = "gdal.grid";
}