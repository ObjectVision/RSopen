//
// Definitie van de verschillende eigendom varianten voor de tredes per Model Variant
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container EigendomVarianten: Descr = "Definitie van de verschillende eigendom varianten voor de tredes per Model Variant"
{
	unit<UInt32> BAU: NrOfRows = 3
	{
		attribute<String> name: ['IsOntwikkelendePartijEnMaatschappelijkEnBinnenBBG', 'OntwikkelendePartijEnCommercieel', 'Totaal'];
		attribute<String> RefSrc := '@S@'+name;
	}
	
	unit<UInt32> Transformeren: NrOfRows = 2 
	{
		attribute<String> name: ['IsOntwikkelendePartijEnMaatschappelijkEnBinnenBBG', 'Totaal'];
		attribute<String> RefSrc := '@S@'+name;
	}
	
	unit<UInt32> Transformeren_Nijverheid: NrOfRows = 2
	{
		attribute<String> name: ['OntwikkelendePartijEnCommercieel', 'Totaal'];
		attribute<String> RefSrc := '@S@'+name;
	}
	
	unit<UInt32> Intensiveren: NrOfRows = 2
	{
		attribute<String> name: ['IsOntwikkelendePartijEnMaatschappelijkEnBinnenBBGOfOntwikkelendePartijEnCommercieel', 'Totaal'];
		attribute<String> RefSrc := '@S@'+name;
	}
}
