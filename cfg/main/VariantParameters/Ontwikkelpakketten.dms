container Ontwikkelpakketten: Descr = "Hier worden de ontwikkelpakketten gedefinieerd die projectontwikkelaars kunnen kiezen bij het ontwikkelen van nieuw woongebied. Deze pakketten zijn gebaseerd op expert judgement van PBL. De pakketten zijn verder uitgewerkt in Default.dms"
{
	parameter<Terreinoppervlak> Terreinoppervlakte := (1[ha])[Terreinoppervlak], Descr = "De standaard terreinoppervlakte van een te ontwikkelen gridcel";
	
	#include<NettoBuurt.dms>
	#include<BrutoBuurt.dms>
	
}