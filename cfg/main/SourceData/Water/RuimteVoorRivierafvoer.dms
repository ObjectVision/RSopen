container RuimteVoorRivierafvoer
{
	unit<UInt32> RuimteVoorDeRivier_GroeneRivieren1
	: StorageName     = "%RSo_DataDir%/Omgeving/Water/RuimteVoorRivierafvoer/BodemEnWaterAlsBasis_2022/RuimteVoorDeRivier_GroeneRivieren.shp"
	, StorageType     = "gdal.vect"
	, StorageReadOnly = "True"
	, Source          = "Aanlevering Bart Rijken 9 februari 2026 per wetransfer, selection veld toegevoegd"
						"Rienk Kuiper 12 januari 2026: BAU en Intensiveren: toevoegen Zutphen + Wijchen (groene rivier ipv retentiegebied)"
	, SqlString       = "SELECT * FROM RuimteVoorDeRivier_GroeneRivieren WHERE selection=1"
	, DialogData      = "rdc_meter"
	{
		attribute<Bool> IsDefined (AdminDomain) := IsDefined(poly2grid(geometry, AdminDomain));
	}
	
	unit<UInt32> RuimteVoorDeRivier_GroeneRivieren2
	: StorageName     = "%RSo_DataDir%/Omgeving/Water/RuimteVoorRivierafvoer/BodemEnWaterAlsBasis_2022/RuimteVoorDeRivier_GroeneRivieren.shp"
