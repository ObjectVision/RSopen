						"Rienk Kuiper 12 januari 2026: En ik zou nog een aanvullend check doen; mijn voorstel is dan om bij Transformeren nog toe te voegen locaties langs de onbedijkte Maas uit Groene Rivieren fig. 3.2 p.3-5"
	, url             = "%RSo_DataDir%/Omgeving/Water/RuimteVoorRivierafvoer/BodemEnWaterAlsBasis_2022/11208014_025_0001.pdf"
	, SqlString       = "SELECT * FROM RuimteVoorDeRivier_GroeneRivieren WHERE sel_trans=1"
	, DialogData      = "rdc_meter"
	{
		attribute<Bool> IsDefined (AdminDomain) := IsDefined(poly2grid(geometry, AdminDomain));
	}
	
