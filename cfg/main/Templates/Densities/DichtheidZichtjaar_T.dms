// Opdrachtgever/ontwikkelaar PBL: Bas van Bemmel (Bas.vanBemmel@pbl.nl)
// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Bevat de sub-items: SectorxSubsectoren, Src.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Template DichtheidZichtjaar_T
: Descr = "Berekent de dichtheden waarmee actoren en objecten in een bepaald zichtjaar worden toegewezen. Per sector en subsector wordt een dichtheid afgeleid, die deels is gebaseerd op de waargenomen dichtheid in het basisjaar en 
	deels op tijdsafhankelijke aanpassingen (zoals de groei van het ruimtebeslag per baan in nijverheid en logistiek). Wordt aangeroepen per zichtjaar."
{
	//
	parameter<Time/Zichtjaar> id;
	//
	
	parameter<String>    Zichtjaar_name     := Time/Zichtjaar/name[id];
	parameter<String>    Zichtjaar_PrevName := Time/Zichtjaar/PrevName[id];
	parameter<YearRange> YearRange_rel      := Time/Zichtjaar/YearRange_rel[id];
	parameter<YearRange> PrevYearRange_rel  := Time/Zichtjaar/PrevYearRange_rel[id];
	parameter<Jaar>      AantalJarenGroeiAanpassing := YearRange_rel > ModelParameters/Werken/Groeifactor/JaarVanafWaarGeenWerkdichtheidMeerAangepastWordt ? 0[jaar] : (YearRange_rel - PrevYearRange_rel)[Jaar], Descr = "Aantal jaren waarover de groeifactor voor het ruimtebeslag per baan (Groeifactor_Nijverheid en Groeifactor_Logistiek) tussen het vorige en huidige zichtjaar wordt toegepast. Wordt op 0 gezet wanneer het zichtjaar voorbij JaarVanafWaarGeenWerkdichtheidMeerAangepastWordt ligt, zodat de extensiveringstrend niet eindeloos lineair wordt doorgetrokken.";

	container SectorxSubsectoren := 
		for_each_ne(
			Sector/xSubsector/name
			, 'Templates/Densities/SectorxSubsector_T('+string(id(Sector/xSubsector))+'[Sector/xSubsector], AllocDomain)'
		);
	
	container Src
	{
		container Werken
		{
			container Subsectoren := for_each_nedv(Actor/Jobs6/name, 'MakeDefined(Banen_perHa/Subsectoren/'+Actor/Jobs6/name+',0f)', AllocDomain, Job_ha);
			
			container PandFootprint_perJob
			: Descr = "Pandvoetafdruk in m2 per baan per subsector. Wordt elk zichtjaar verhoogd met (1 + Groeifactor * AantalJarenGroeiAanpassing) ten opzichte van het vorige zichtjaar. De groeifactor is gebaseerd op de waargenomen jaarlijkse stijging van het ruimtebeslag per baan tussen 1996 en 2019."
			{
				container Src := = iif(id > 0[Time/Zichtjaar], Zichtjaar_PrevName+'/Src/Werken/PandFootprint_perJob/Subsectoren', 'Basisjaar/PandFootprint_perJob');
				
				container Subsectoren0 := 
					for_each_nedv(
						Actor/Jobs6/name
						, '(Src/'+Actor/Jobs6/name+' * (1f + (VariantParameters/VariantK/Groeifactor_'+Actor/Jobs6/name+'[VariantParameters/VariantK/V/'+Variant_name+'] * AantalJarenGroeiAanpassing)))'
						, AllocDomain
						, m2PandFootprint_job
				), Descr = "Pandvoetafdruk per baan per subsector, met de variantspecifieke groeifactor lineair toegepast op het aantal jaren sinds het vorige zichtjaar.";

				container Subsectoren := Subsectoren0;
			}
			
			container Job_Perm2PandFootprint
			: Descr = "Banen per m2 pandvoetafdruk, ofwel de inverse van PandFootprint_perJob. Wordt los uitgerekend omdat zakelijke dienstverlening hier een afwijkende groeifactor krijgt (m2BVO_job_Kantoor_groeifactor) die de juist afnemende ruimtevraag per kantoorbaan reflecteert."
			{
				container Src := = iif(id > 0[Time/Zichtjaar], Zichtjaar_PrevName+'/Src/Werken/Job_Perm2PandFootprint/Subsectoren', 'Basisjaar/Job_Perm2PandFootprint');
				
				container Subsectoren0 := //uitkomst in job/m2, factor gaat over groei m2/job. Src=job/m2
					for_each_nedv(
						Actor/Jobs6/name 
						, '1f / ((1f / Src/'+Actor/Jobs6/name+') * (1f + (VariantParameters/VariantK/Groeifactor_'+Actor/Jobs6/name+'[VariantParameters/VariantK/V/'+Variant_name+'] * AantalJarenGroeiAanpassing)))'
						, AllocDomain
						, job_m2PandFootprint
					), Descr = "Banen per m2 per subsector. De groeifactor gaat over de groei van m2 per baan; deze wordt hier omgedraaid zodat de uitkomst in baan per m2 staat.";

				container Subsectoren := Subsectoren0
				{
					attribute<job_m2PandFootprint> Zak_dienstverlening (AllocDomain) := = '1f / ((1f / Subsectoren0/Zak_dienstverlening) * (1f + (VariantParameters/VariantK/m2BVO_job_Kantoor_groeifactor[VariantParameters/VariantK/V/'+Variant_name+'])))', Descr = "Overschrijft de standaardwaarde voor zakelijke dienstverlening met een eigen groeifactor (m2BVO_job_Kantoor_groeifactor). De kantorenliteratuur en empirische data laten zien dat het ruimtebeslag per kantoorbaan over de tijd afneemt in plaats van toeneemt.";
				}
			}
			
			container Banen_perHa
			: Descr = "Banen per hectare per subsector. Berekend door banen per m2 pandvoetafdruk te vermenigvuldigen met de pandvoetafdruk per hectare uit het basisjaar."
			{
				container Subsectoren := 
					for_each_nedv(
						Actor/Jobs6/name
						, 'Job_Perm2PandFootprint/Subsectoren/'+Actor/Jobs6/name+' * Basisjaar/PandFootprint_perHa/'+Actor/Jobs6/name+'/result'
						, AllocDomain
						, Job_ha
				);
			}
			
			container Basisjaar := BaseData/StartState/StateBasisjaar/State/Werken
			{
				container PandFootprint_perJob   := for_each_nedv(Actor/Jobs6/name, 'BaseData/Densities/PandFootprint_baan/result/'+Actor/Jobs6/name, AllocDomain, m2PandFootprint_job);
				container Job_Perm2PandFootprint := for_each_nedv(Actor/Jobs6/name, 'MakeDefined(1f / PandFootprint_perJob/'+Actor/Jobs6/name+', 0f)', AllocDomain, job_m2PandFootprint);
				container PandFootprint_perHa    := for_each_ne(Actor/Jobs6/name, 'Templates/Densities/Werken_T(Actor/Jobs6, '+string(id(Actor/Jobs6))+'[Actor/Jobs6], BaseData/Startstate/PandFootprint, AllocDomain)');
			}
		}
		
		container Zon
		: Descr = "Dichtheid voor de allocatie van zonneparken, uitgedrukt in MW per hectare. Wanneer de variant toestaat om zon te combineren met bestaande groen-locaties, wordt op die plekken een lager vermogen per hectare aangehouden."
		{
			container Subsectoren
			{
				attribute<MW_ha> Totaal (AllocDomain) :=
					VariantK/ZonCombinerenMetBestaandGroen[Variant_rel] && BaseData/StartState/Grondgebruik/Per_AllocDomain/IsGroen 
						? const(ModelParameters/Zon/Vermogen_ha[MW_ha], AllocDomain) * ModelParameters/Zon/FractieVermogenHaIndienZonCombinerenMetBestaandGroen 
						: const(ModelParameters/Zon/Vermogen_ha[MW_ha], AllocDomain);
			}
		}
		
		container Waterberging
		: Descr = "Bergingscapaciteit voor water per hectare, afgeleid uit de dieptekaart. Wordt gebruikt om de regionale opgave voor waterberging te alloceren op basis van de fysieke capaciteit van een locatie."
		{
			container Subsectoren
			{
				attribute<meter3_ha> Totaal (AllocDomain) := sum(SourceData/Water/Dieptekaart * AdminDomain/NrMeter2PerCell, AdminDomain/AllocDomain_rel) / AllocDomain/NrHaPerCell;
			}
		}
	}
}
