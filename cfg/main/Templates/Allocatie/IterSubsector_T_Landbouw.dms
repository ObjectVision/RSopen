// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Beschikbaar voor allocatie in dit zichtjaar. en waar nog niet eerder is gealloceerd, geen extra restricties
// vanwege windmolens, niet vanwege huidige zonneweides en of de minimal landavailability gehaald wordt.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Template IterSubsector_T_Landbouw
{
	parameter<Subsector> id;
	unit<UInt8> Subsector;
	container StateVoorAllocatie;
	container Context0;
	//
	
	container Context := Context0
	{
		container ThisSubsector := ..;
	}
	
	parameter<String> name               := Subsector/name[id];
	parameter<String> Subsector_pathname := Subsector/Sector_name_Thisname[id];
	parameter<String> Zichtjaar_name     := Context/ThisZichtjaar/name;
	parameter<String> AllocRegio_name    := Context/ThisSectorAllocRegio/AllocRegio_name;
	
	unit<uint64> CompactedAdminDomain := Geography/CompactedAdminDomain
	{ 
		attribute<Bool>    Beschikbaar                     := = 'ThisVariantData/PotentieleState/'+Zichtjaar_name+'/per_SectorxSubsectoren/'+Subsector_pathname+'/IsBeschikbaar_zichtjaar 
																		&& IsNull(StateVoorAllocatie/SubSector_rel) 
																		&& !ExtraRestrictieDoorHuidigeZonneweide 
																		&& !GeeftOnvoldoendeRuimte_Landbouw', Descr = "Beschikbaar voor allocatie in dit zichtjaar. en waar nog niet eerder is gealloceerd, geen extra restricties vanwege windmolens, niet vanwege huidige zonneweides en of de minimal landavailability gehaald wordt.";
																		// && !ExtraRestrictieDoorWindAllocatie  //vgm is dit niet nodig voor landbouw allocatie!
																		
																		
		attribute<Bool>    GeeftOnvoldoendeRuimte_Landbouw := = 'ThisVariantData/Zeef/'+Zichtjaar_name+'/SectorxSubsectoren/'+Subsector_pathname+'/src/GeeftOnvoldoendeRuimte_Landbouw';
	}
}