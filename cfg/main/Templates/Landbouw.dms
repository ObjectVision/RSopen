// Opdrachtgever/ontwikkelaar PBL: Bas van Bemmel (Bas.vanBemmel@pbl.nl)
// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// yield reduction tbv HELP yield reduction berekening Uiteindelijke suitability die aan de alloc module wordt
// meegegeven. Laadt via #include: Dairy_T.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container Landbouw : using = "Classifications/Landbouw;Classifications/Actor"
{
	Template Suitability_T
	{
		//
		parameter<String> Zichtjaar_name;
		parameter<String> Waterbeheeroptie_name;  //fka DeepDrainageVariant_name
		//
		
		parameter<YearRange>     StartYear                := rjoin(lowercase(Zichtjaar_name), lowercase(Zichtjaar/name), Zichtjaar/PrevYearRange_rel);
		parameter<YearRange>     EndYear                  := rjoin(lowercase(Zichtjaar_name), lowercase(Zichtjaar/name), Zichtjaar/YearRange_rel);
		parameter<DeepDrainageK> DeepDrainageVariant      := ='WaterbeheerOpties/DeepDrainageK_rel[WaterbeheerOpties/v/'+Waterbeheeroptie_name+']';
		parameter<Jaar>          PeriodDuRation           := (EndYear - StartYear)[jaar];
		parameter<Int16>         StYrPhoenix              := int16(round(float32(StartYear)/10f) * 10i);
		parameter<String>        StYrPhoenixStr           := rjoin(StYrPhoenix, Phoenix/Zichtjaar/StartYearPhoenix, Phoenix/Zichtjaar/namePhoenix);
		parameter<String>        EndYrPhoenixStr          := rjoin(EndYear, Phoenix/Zichtjaar/EndYearPhoenix, Phoenix/Zichtjaar/namePhoenix);
		attribute<LU_ModelType>  gg_LandbouwK   (rdc_25m) := BaseData/StartState/Grondgebruik/Per_AdminDomain/gg_Landbouw;
		attribute<Bool>          gg_IsStedelijk (rdc_25m) := BaseData/StartState/Grondgebruik/Per_AdminDomain/IsWoonlocatie || BaseData/StartState/Grondgebruik/Per_AdminDomain/IsWerklocatie;
		
		attribute<HELPbodems>    BodemType      (rdc_25m) := SourceData/Landbouw/HELPbodemsNL;
		unit<UInt8>              ModelType                := LandbouwKlasses;
		parameter<Float32>       RentevoetDezeBoer        := = 'ModelParameters/Landbouw/Rentevoet_'+Boervariant_name;
		
		attribute<bool>          IsVeenGrond    (rdc_25m) := /sourcedata/Landbouw/Peat_thickness > 0.5[meter]; //to do: is dit een juiste rekenregel? betere data? wat gebruikt overheid?
		
		parameter<Eur_Ha_jaarlijks> GLB_EcoRegeling_Verwacht := VariantParameters/VariantK/GLB_EcoRegeling_Fractie_Goud[variant_rel]   * VariantParameters/VariantK/GLB_EcoRegeling_Bedrag_Goud[variant_rel]
																  + VariantParameters/VariantK/GLB_EcoRegeling_Fractie_Zilver[variant_rel] * VariantParameters/VariantK/GLB_EcoRegeling_Bedrag_Zilver[variant_rel]
																  + VariantParameters/VariantK/GLB_EcoRegeling_Fractie_Brons[variant_rel]  * VariantParameters/VariantK/GLB_EcoRegeling_Bedrag_Brons[variant_rel];

		attribute<Eur_Ha_jaarlijks> ANLb_veen_Verwacht (rdc_25m) := IsVeengrond ? VariantParameters/VariantK/ANLb_veen_Fractie[variant_rel] * VariantParameters/VariantK/ANLb_veen_Bedrag[variant_rel] : 0[Eur_Ha_jaarlijks];
		attribute<Eur_Ha_jaarlijks> TotaalSubsidie     (rdc_25m) := VariantParameters/VariantK/GLB_Basispremie[variant_rel] + GLB_EcoRegeling_Verwacht + ANLb_veen_Verwacht;
		
		container Factoren 
		{
			container Transitiekosten := 
				for_each_nedv(
					LandbouwKlasses/name
					, 'ModelParameters/Landbouw/Transitiekosten/'+ LandbouwKlasses/name
					, LandbouwKlasses
					, EUR_ha
				);
			
			container YieldReduction : Descr = "yield reduction"
			{
				attribute<Bool> AangetastVerziltGebied (rdc_25m) := SourceData/Landbouw/AangetastVerziltGebied;
				
				parameter<Float32> MateAantastingVerziltingZichtjaar := lowercase(Zichtjaar_name) == lowercase('Y2030')
					? ModelParameters/Landbouw/Verzilt_OpbrengstDerving_Y2030 
					: ModelParameters/Landbouw/Verzilt_OpbrengstDerving_Y2030 == 1f
						? ModelParameters/Landbouw/Verzilt_OpbrengstDerving
						: (float32(EndYear - 2030[YearRange]) / 10f) * (ModelParameters/Landbouw/Verzilt_OpbrengstDerving / (float32(ModelParameters/Model_FinalYear - 2030[YearRange]) / 10f)); 
				
				container Result :=
					for_each_nedv(
						 GewasSoortYR/name
						,'min_elem('+GewasSoortYR/YR_bron+'/'+GewasSoortYR/name+' + float32(AangetastVerziltGebied) * MateAantastingVerziltingZichtjaar * float32('+string(GewasSoortYR/AantastingDoorVerzilt)+'), 1f)'
						, rdc_25m
						, float32
					);
				
				container WWL := 
					for_each_nedv(
						WWL_GewasSoort/name
						, 'MakeDefined(SourceData/Landbouw/Yield_Reduction/WWL_'+Variant_name+'/'+WWL_GewasSoort/name+' / 100f, ModelParameters/Landbouw/YieldReduction_NoData)'
						, rdc_25m
						, float32
					);
					
				container WWL2 := 
					for_each_nedv(
						Classifications/Landbouw/BeregeningsScenarioGewassen/name
						, 'MakeDefined(
							SourceData/Landbouw/Yield_Reduction/BeregeningScenario_Lokaal_WWL/'+Variant_name+'/'+/BeregeningScenario_name+'/Read/'+Classifications/Landbouw/BeregeningsScenarioGewassen/name+',
							MakeDefined(
								mean(SourceData/Landbouw/Yield_Reduction/BeregeningScenario_Lokaal_WWL/'+Variant_name+'/'+/BeregeningScenario_name+'/Read/'+Classifications/Landbouw/BeregeningsScenarioGewassen/name+', rdc_25m/rdc_500m_rel)[rdc_25m/rdc_500m_rel],
								mean(SourceData/Landbouw/Yield_Reduction/BeregeningScenario_Lokaal_WWL/'+Variant_name+'/'+/BeregeningScenario_name+'/Read/'+Classifications/Landbouw/BeregeningsScenarioGewassen/name+')
							)
						) / 100f'
						, rdc_25m
						, float32
					);
				
				container Exotisch :=
					for_each_nedv(
						Exotische_GewasSoort/name
						, 'MakeDefined(1f - SourceData/Landbouw/WUR_Kansenkaarten/PerVariant/'+variant_name+'/Kansenkaarten/'+Exotische_GewasSoort/name+', ModelParameters/Landbouw/YieldReduction_NoData)'
						, rdc_25m
						, float32
					); 
				
				container YieldReduction_HELP := 
					for_each_nedv(
						HELP_GewasSoort/name
						, 'MakeDefined(HELP_StartYr/YieldReduction/'+HELP_GewasSoort/name+'/Result + HELP_EndYr/YieldReduction/'+HELP_GewasSoort/name+'/Result / 2f, ModelParameters/Landbouw/YieldReduction_NoData)' 
						, rdc_25m
						, float32
					);
				
				container HELP_StartYr := HELP_Year_T(StYrPhoenixStr), Descr = "tbv HELP yield reduction berekening";
				container HELP_EndYr   := HELP_Year_T(EndYrPhoenixStr), Descr = "tbv HELP yield reduction berekening";
				
				Template HELP_Year_T : Descr = "tbv HELP yield reduction berekening"
				{
					//
					parameter<String> Year;
					//
					
					container Peil := 
						for_each_ne(
							PeilK/name
							, 'Peil_T('+string(id(PeilK))+'[PeilK])'
						);
					
					container YieldReduction := 
						for_each_ne(
							HELP_GewasSoort/name
							, 'YieldReduction_T(HELP_GewasSoort/V/'+HELP_GewasSoort/name+')'
						);
					
					Template Peil_T
					{
						//
						parameter<PeilK> id;
						//
						parameter<String> Peilname                    := PeilK/name[id];  
						
						attribute<UInt32> ResultDDOption   (rdc_25m) := ='SourceData/Landbouw/HELP/'+Peilname+'_merged_'+VariantK/PeilStrategie[/Variant_rel]+'_DD/'+Year+'[rdc_25m/rdc_100m_rel]';
						attribute<UInt32> ResultNoDDOption (rdc_25m) := ='SourceData/Landbouw/HELP/'+Peilname+'_merged_'+VariantK/PeilStrategie[/Variant_rel]+'_NoDD/'+Year+'[rdc_25m/rdc_100m_rel]';
						attribute<UInt32> Result           (rdc_25m) := SourceData/Landbouw/DDPossible ? ResultDDOption: ResultNoDDOption;
					}
					
					Template YieldReduction_T
					{
						//
						parameter<HELP_GewasSoort> id;
						//
						
						attribute<String> code (rdc_25m) :=
							HELP_GewasSoort/HELP_Code[id] + '_' +
							HELPbodems/code[BodemType] + '_'+
							GLGHelpKlasse/code[Peil/GLG/Result] + '-' +
							GHGHelpKlasse/code[Peil/GHG/Result];
						
						attribute<Float32> result (rdc_25m) :=
								rjoin(
									  code
									, OpbrengstDerving/code
									, OpbrengstDerving/TS
								);
					}
				}
			}
		}
		
		container per_ModelType := 
			for_each_ne(
				LandbouwKlasses/name
				, LandbouwKlasses/Templatetype+'_T('+quote(LandbouwKlasses/name)+')'
			), using = "ModelParameters/Landbouw"
		{
			container NonLandbouw
			{
				attribute<Eur_m2>           Totaal (rdc_25m) := const(0[Eur_m2], rdc_25m);
				attribute<Eur_m2>           NPV    (rdc_25m) := Totaal;
				
				attribute<Float32>          Suitability (rdc_25m) := Totaal, Descr = "Uiteindelijke suitability die aan de alloc module wordt meegegeven.";
			}
		}
	}
	
	#include<Dairy_T.dms>
	#include<Akkerbouw_T.dms>
}