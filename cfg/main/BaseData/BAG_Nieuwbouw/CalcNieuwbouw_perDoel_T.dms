// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Calculaties voor nieuwbouw per gebruiksdoel (Wonen, Kantoor, Logies, etc) Nieuwe VBO's (nieuwbouw en
// toevoeging) tussen modeljaar en recentste jaar per gebruiksdoel count uitgesmeerde woningen per WP2 over
// CompactedAdminDomain
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

Template CalcNieuwbouw_perDoel_T
: Descr = "Calculaties voor nieuwbouw per gebruiksdoel (Wonen, Kantoor, Logies, etc)"
{
	parameter<String> doel;
	//
	
	unit<UInt32> NieuwVBO_TussenModelenRecentJaar_PerDoel := ='select_with_org_rel(BAG_nieuwbouw/NieuwVBO_TussenModelenRecentJaar/gebruiksdoelen/'+doel+')' 
	, Descr = "Nieuwe VBO's (nieuwbouw en toevoeging) tussen modeljaar en recentste jaar per gebruiksdoel"
	{
		unit<uint32> src := .;
		attribute<rdc_meter>       geometry    := org_rel -> geometry;
		attribute<uint64>          vbo_bag_nr  := org_rel -> vbo_bag_nr;
		attribute<gerelateerdPand> gerelateerdPand_rel    := rlookup(vbo_bag_nr, gerelateerdPand/vbo_bag_nr);
		attribute<m2_vbo>          vbo_opp     := org_rel -> oppervlakte_trunc;
		attribute<m2PandFootprint> Footprint   := ='org_rel -> Footprint_perGebruiksdoel/'+doel+' / org_rel -> Vbos_InPand_perGebruiksdoel/'+doel;
		attribute<Vastgoed/WP2>    WP2_rel     := org_rel -> WP2_rel;
		attribute<Vastgoed/WP4>    WP4_rel     := org_rel -> WP4_rel;
		
		unit<uint32> vbo_domain  := NieuwVBO_TussenModelenRecentJaar;
		unit<uint32> pand_domain := vbo_domain/pand_domain;
		
		unit<UInt32> gerelateerdPand := select_with_org_rel(IsDefined(rlookup(vbo_domain/gerelateerdPand/vbo_bag_nr, ./vbo_bag_nr)) 
																	&& IsDefined(rlookup(vbo_domain/gerelateerdPand/pand_bag_nr, pand_domain/pand_bag_nr)))
		{
			attribute<uint64>                vbo_bag_nr              := org_rel -> vbo_bag_nr;
			attribute<uint64>                pand_bag_nr             := org_rel -> gerelateerdPand/pand_bag_nr;
		
			attribute<..>                    vbo_rel                 := rlookup(vbo_bag_nr, ../vbo_bag_nr);
			attribute<pand_domain>           pand_rel                := rlookup(pand_bag_nr, pand_domain/pand_bag_nr);
			attribute<WP5>                   WP5_rel                 := Pand_rel -> WP5_rel;
		}
		
		container count_Per_CompactedAdminDomain_WP2 :=
			for_each_nedv(
				Vastgoed/WP2/name
				, 'Uitsmeren_WP2/'+Vastgoed/WP2/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP2 over CompactedAdminDomain"
		{
			attribute<woning> Totaal (CompactedAdminDomain) := ='add('+AsItemList(Vastgoed/WP2/name)+')';
		}
		
		container count_Per_CompactedAdminDomain_WP4 :=
			for_each_nedv(
				Vastgoed/WP4/name
				, 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP4 over CompactedAdminDomain"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		// container Opp_Per_CompactedAdminDomain_WP4 :=
			// for_each_nedv(
				// Vastgoed/WP4/name
				// , 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Woon_gebruiksoppervlak_Per_CompactedAdminDomain'
				// , CompactedAdminDomain
				// , meter2
			// ), Descr = "woon gebruiksoppervlak per compacted admin domain"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_WP2 :=
			for_each_ne(
				Vastgoed/WP2/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP2/name)+', ''WP2'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_voorraad'', ''NieuwVBO_TussenModelenRecentJaar_PerDoel'')'
			), Descr = "uitsmeren per WP2";
		
		container Uitsmeren_WP4 :=
			for_each_ne(
				Vastgoed/WP4/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP4/name)+', ''WP4'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_voorraad'', ''NieuwVBO_TussenModelenRecentJaar_PerDoel'')'
			), Descr = "uitsmeren per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_Totaal := Uitsmeren_T('Totaal', 'Totaal', 'BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_voorraad', 'NieuwVBO_TussenModelenRecentJaar_PerDoel');
	}
	unit<UInt32> NieuwVBO_NaRecentJaarWelActief_PerDoel := ='select_with_org_rel(BAG_nieuwbouw/NieuwVBO_NaRecentJaarWelActief/gebruiksdoelen/'+doel+')'
	, Descr = "Nieuwe VBO's (nieuwbouw en toevoeging) tussen modeljaar en recentste jaar per gebruiksdoel"
	{
		unit<uint32> src := .;
		attribute<rdc_meter>       geometry    := org_rel -> geometry;
		attribute<uint64>          vbo_bag_nr  := org_rel -> vbo_bag_nr;
		attribute<gerelateerdPand> gerelateerdPand_rel    := rlookup(vbo_bag_nr, gerelateerdPand/vbo_bag_nr);
		attribute<m2_vbo>          vbo_opp     := org_rel -> oppervlakte_trunc;
		attribute<m2PandFootprint> Footprint   := ='org_rel -> Footprint_perGebruiksdoel/'+doel+' / org_rel -> Vbos_InPand_perGebruiksdoel/'+doel;
		attribute<Vastgoed/WP2>    WP2_rel     := org_rel -> WP2_rel;
		attribute<Vastgoed/WP4>    WP4_rel     := org_rel -> WP4_rel;
		
		unit<uint32> vbo_domain  := NieuwVBO_NaRecentJaarWelActief;
		unit<uint32> pand_domain := vbo_domain/pand_domain;
		
		unit<UInt32> gerelateerdPand := select_with_org_rel(IsDefined(rlookup(vbo_domain/gerelateerdPand/vbo_bag_nr, ./vbo_bag_nr)) 
																	&& IsDefined(rlookup(vbo_domain/gerelateerdPand/pand_bag_nr, pand_domain/pand_bag_nr)))
		{
			attribute<uint64>                vbo_bag_nr              := org_rel -> vbo_bag_nr;
			attribute<uint64>                pand_bag_nr             := org_rel -> gerelateerdPand/pand_bag_nr;
		
			attribute<..>                    vbo_rel                 := rlookup(vbo_bag_nr, ../vbo_bag_nr);
			attribute<pand_domain>           pand_rel                := rlookup(pand_bag_nr, pand_domain/pand_bag_nr);
			attribute<WP5>                   WP5_rel                 := Pand_rel -> WP5_rel;
		}
		
		container count_Per_CompactedAdminDomain_WP2 :=
			for_each_nedv(
				Vastgoed/WP2/name
				, 'Uitsmeren_WP2/'+Vastgoed/WP2/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP2 over CompactedAdminDomain"
		{
			attribute<woning> Totaal (CompactedAdminDomain) := ='add('+AsItemList(Vastgoed/WP2/name)+')';
		}
		
		container count_Per_CompactedAdminDomain_WP4 :=
			for_each_nedv(
				Vastgoed/WP4/name
				, 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP4 over CompactedAdminDomain"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_WP2 :=
			for_each_ne(
				Vastgoed/WP2/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP2/name)+', ''WP2'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand'', ''NieuwVBO_NaRecentJaarWelActief_PerDoel'')'
			), Descr = "uitsmeren per WP2";
		
		container Uitsmeren_WP4 :=
			for_each_ne(
				Vastgoed/WP4/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP4/name)+', ''WP4'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand'', ''NieuwVBO_NaRecentJaarWelActief_PerDoel'')'
			), Descr = "uitsmeren per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_Totaal := Uitsmeren_T('Totaal', 'Totaal', 'BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand', 'NieuwVBO_NaRecentJaarWelActief_PerDoel');
	}
	
	
	unit<UInt32> NieuwVBO_NaRecentJaar_PerDoel := ='select_with_org_rel(BAG_nieuwbouw/NieuwVBO_NaRecentJaar/gebruiksdoelen/'+doel+')'
	, Descr = "Nieuwe VBO's (nieuwbouw en toevoeging) tussen modeljaar en recentste jaar per gebruiksdoel"
	{
		unit<uint32> src := .;
		attribute<rdc_meter>       geometry    := org_rel -> geometry;
		attribute<uint64>          vbo_bag_nr  := org_rel -> vbo_bag_nr;
		attribute<gerelateerdPand> gerelateerdPand_rel    := rlookup(vbo_bag_nr, gerelateerdPand/vbo_bag_nr);
		attribute<m2_vbo>          vbo_opp     := org_rel -> oppervlakte_trunc;
		attribute<m2PandFootprint> Footprint   := ='org_rel -> Footprint_perGebruiksdoel/'+doel+' / org_rel -> Vbos_InPand_perGebruiksdoel/'+doel;
		attribute<Vastgoed/WP2>    WP2_rel     := org_rel -> WP2_rel;
		attribute<Vastgoed/WP4>    WP4_rel     := org_rel -> WP4_rel;
		
		unit<uint32> vbo_domain  := NieuwVBO_NaRecentJaar;
		unit<uint32> pand_domain := vbo_domain/pand_domain;
		
		unit<UInt32> gerelateerdPand := select_with_org_rel(IsDefined(rlookup(vbo_domain/gerelateerdPand/vbo_bag_nr, ./vbo_bag_nr)) 
																	&& IsDefined(rlookup(vbo_domain/gerelateerdPand/pand_bag_nr, pand_domain/pand_bag_nr)))
		{
			attribute<uint64>                vbo_bag_nr              := org_rel -> vbo_bag_nr;
			attribute<uint64>                pand_bag_nr             := org_rel -> gerelateerdPand/pand_bag_nr;
		
			attribute<..>                    vbo_rel                 := rlookup(vbo_bag_nr, ../vbo_bag_nr);
			attribute<pand_domain>           pand_rel                := rlookup(pand_bag_nr, pand_domain/pand_bag_nr);
			attribute<WP5>                   WP5_rel                 := Pand_rel -> WP5_rel;
		}
		
		container count_Per_CompactedAdminDomain_WP2 :=
			for_each_nedv(
				Vastgoed/WP2/name
				, 'Uitsmeren_WP2/'+Vastgoed/WP2/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP2 over CompactedAdminDomain"
		{
			attribute<woning> Totaal (CompactedAdminDomain) := ='add('+AsItemList(Vastgoed/WP2/name)+')';
		}
		
		container count_Per_CompactedAdminDomain_WP4 :=
			for_each_nedv(
				Vastgoed/WP4/name
				, 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "count uitgesmeerde woningen per WP4 over CompactedAdminDomain"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_WP2 :=
			for_each_ne(
				Vastgoed/WP2/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP2/name)+', ''WP2'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst'', ''NieuwVBO_NaRecentJaar_PerDoel'')'
			), Descr = "uitsmeren per WP2";
		
		container Uitsmeren_WP4 :=
			for_each_ne(
				Vastgoed/WP4/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP4/name)+', ''WP4'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst'', ''NieuwVBO_NaRecentJaar_PerDoel'')'
			), Descr = "uitsmeren per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_Totaal := Uitsmeren_T('Totaal', 'Totaal', 'BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst', 'NieuwVBO_NaRecentJaar_PerDoel');
	}
	
	unit<UInt32> WegVBO_TussenModelenRecentJaar_PerDoel := ='select_with_org_rel(BAG_nieuwbouw/WegVBO_TussenModelenRecentJaar/gebruiksdoelen/'+doel+')' //fka VBOsWegTussenModelenRecentJaar
	, Descr = "VBO's (sloop en onttrekking) die zijn weggegaan tussen modeljaar en recentste jaar per gebruiksdoel"
	{
		unit<uint32> src := .;
		attribute<rdc_meter>       geometry    := org_rel -> geometry;
		attribute<uint64>          vbo_bag_nr  := org_rel -> vbo_bag_nr;
		attribute<gerelateerdPand> gerelateerdPand_rel    := rlookup(vbo_bag_nr, gerelateerdPand/vbo_bag_nr);
		attribute<m2_vbo>          vbo_opp     := org_rel -> oppervlakte_trunc;
		attribute<m2PandFootprint> Footprint   := ='org_rel -> Footprint_perGebruiksdoel/'+doel+' / org_rel -> Vbos_InPand_perGebruiksdoel/'+doel;
		attribute<Vastgoed/WP2>    WP2_rel     := org_rel -> WP2_rel;
		attribute<Vastgoed/WP4>    WP4_rel     := org_rel -> WP4_rel;
		
		unit<uint32> vbo_domain  := WegVBO_TussenModelenRecentJaar;
		unit<uint32> pand_domain := vbo_domain/pand_domain;
		
		unit<UInt32> gerelateerdPand := select_with_org_rel(IsDefined(rlookup(vbo_domain/gerelateerdPand/vbo_bag_nr, ./vbo_bag_nr)) 
																	&& IsDefined(rlookup(vbo_domain/gerelateerdPand/pand_bag_nr, pand_domain/pand_bag_nr)))
		{
			attribute<uint64>                vbo_bag_nr              := org_rel -> vbo_bag_nr;
			attribute<uint64>                pand_bag_nr             := org_rel -> gerelateerdPand/pand_bag_nr;
		
			attribute<..>                    vbo_rel                 := rlookup(vbo_bag_nr, ../vbo_bag_nr);
			attribute<pand_domain>           pand_rel                := rlookup(pand_bag_nr, pand_domain/pand_bag_nr);
			attribute<WP5>                   WP5_rel                 := Pand_rel -> WP5_rel;
		}
		
		container count_Per_CompactedAdminDomain_WP2xVSSH :=
			for_each_nedv(
				Vastgoed/WP2xVSSH/name
				, 'Uitsmeren_WP2/'+Vastgoed/WP2xVSSH/WP_name+'/Aantal_Woningen_'+Vastgoed/WP2xVSSH/VSSH_name+'_Per_CompactedAdminDomain'   
				, CompactedAdminDomain
				, Woning
			), Descr = "Uitgesmeerde count woningen per WP2xVSSH over CompactedAdminDomain"
		{
			attribute<woning> Totaal (CompactedAdminDomain) := ='add('+AsItemList(Vastgoed/WP2xVSSH/name)+')';
		}
		
		container count_Per_CompactedAdminDomain_WP4 :=
			for_each_nedv(
				Vastgoed/WP4/name
				, 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "Uitgesmeerde count woningen per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		// container Opp_Per_CompactedAdminDomain_WP4 :=
			// for_each_nedv(
				// Vastgoed/WP4/name
				// , 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Woon_gebruiksoppervlak_Per_CompactedAdminDomain'
				// , CompactedAdminDomain
				// , meter2
			// ), Descr = "Uitgesmeerd woon opp per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_WP2 :=
			for_each_ne(
				Vastgoed/WP2/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP2/name)+', ''WP2'', ''BaseData/StartState/BAG_nieuwbouw/BAG_ModelJaar_pand_voorraad'', ''WegVBO_TussenModelenRecentJaar_PerDoel'')'
			), Descr = "Uitsmeren per WP2";
		
		container Uitsmeren_WP4 :=
			for_each_ne(
				Vastgoed/WP4/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP4/name)+', ''WP4'', ''BaseData/StartState/BAG_nieuwbouw/BAG_ModelJaar_pand_voorraad'', ''WegVBO_TussenModelenRecentJaar_PerDoel'')'
			), Descr = "Uitsmeren per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_Totaal := Uitsmeren_T('Totaal', 'Totaal', 'BaseData/StartState/BAG_nieuwbouw/BAG_ModelJaar_pand_voorraad', 'WegVBO_TussenModelenRecentJaar_PerDoel');
	}
	
	unit<UInt32> WegVBO_NaRecentJaar_PerDoel := ='select_with_org_rel(BAG_nieuwbouw/WegVBO_NaRecentJaar/gebruiksdoelen/'+doel+')' 
	, Descr = "VBO's (sloop en onttrekking) die zijn weggegaan tussen modeljaar en recentste jaar per gebruiksdoel"
	{
		unit<uint32> src := .;
		attribute<rdc_meter>       geometry    := org_rel -> geometry;
		attribute<uint64>          vbo_bag_nr  := org_rel -> vbo_bag_nr;
		attribute<gerelateerdPand> gerelateerdPand_rel    := rlookup(vbo_bag_nr, gerelateerdPand/vbo_bag_nr);
		attribute<m2_vbo>          vbo_opp     := org_rel -> oppervlakte_trunc;
		attribute<m2PandFootprint> Footprint   := ='org_rel -> Footprint_perGebruiksdoel/'+doel+' / org_rel -> Vbos_InPand_perGebruiksdoel/'+doel;
		attribute<Vastgoed/WP2>    WP2_rel     := org_rel -> WP2_rel;
		attribute<Vastgoed/WP4>    WP4_rel     := org_rel -> WP4_rel;
		
		unit<uint32> vbo_domain  := WegVBO_NaRecentJaar;
		unit<uint32> pand_domain := vbo_domain/pand_domain;
		
		unit<UInt32> gerelateerdPand := select_with_org_rel(IsDefined(rlookup(vbo_domain/gerelateerdPand/vbo_bag_nr, ./vbo_bag_nr)) 
																	&& IsDefined(rlookup(vbo_domain/gerelateerdPand/pand_bag_nr, pand_domain/pand_bag_nr)))
		{
			attribute<uint64>                vbo_bag_nr              := org_rel -> vbo_bag_nr;
			attribute<uint64>                pand_bag_nr             := org_rel -> gerelateerdPand/pand_bag_nr;
		
			attribute<..>                    vbo_rel                 := rlookup(vbo_bag_nr, ../vbo_bag_nr);
			attribute<pand_domain>           pand_rel                := rlookup(pand_bag_nr, pand_domain/pand_bag_nr);
			attribute<WP5>                   WP5_rel                 := Pand_rel -> WP5_rel;
		}
		
		container count_Per_CompactedAdminDomain_WP2xVSSH :=
			for_each_nedv(
				Vastgoed/WP2xVSSH/name
				, 'Uitsmeren_WP2/'+Vastgoed/WP2xVSSH/WP_name+'/Aantal_Woningen_'+Vastgoed/WP2xVSSH/VSSH_name+'_Per_CompactedAdminDomain'   
				, CompactedAdminDomain
				, Woning
			), Descr = "Uitgesmeerde count woningen per WP2xVSSH over CompactedAdminDomain"
		{
			attribute<woning> Totaal (CompactedAdminDomain) := ='add('+AsItemList(Vastgoed/WP2xVSSH/name)+')';
		}
		
		container count_Per_CompactedAdminDomain_WP4 :=
			for_each_nedv(
				Vastgoed/WP4/name
				, 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Aantal_Woningen_Per_CompactedAdminDomain'
				, CompactedAdminDomain
				, Woning
			), Descr = "Uitgesmeerde count woningen per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		// container Opp_Per_CompactedAdminDomain_WP4 :=
			// for_each_nedv(
				// Vastgoed/WP4/name
				// , 'Uitsmeren_WP4/'+Vastgoed/WP4/name+'/Woon_gebruiksoppervlak_Per_CompactedAdminDomain'
				// , CompactedAdminDomain
				// , meter2
			// ), Descr = "Uitgesmeerd woon opp per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_WP2 :=
			for_each_ne(
				Vastgoed/WP2/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP2/name)+', ''WP2'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst'', ''WegVBO_NaRecentJaar_PerDoel'')'
			), Descr = "Uitsmeren per WP2";
		
		container Uitsmeren_WP4 :=
			for_each_ne(
				Vastgoed/WP4/name
				, 'Uitsmeren_T('+quote(Vastgoed/WP4/name)+', ''WP4'', ''BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst'', ''WegVBO_NaRecentJaar_PerDoel'')'
			), Descr = "Uitsmeren per WP4"; //relevant voor /Indicatoren/BAGSloopNieuwbouwWonen
		
		container Uitsmeren_Totaal := Uitsmeren_T('Totaal', 'Totaal', 'BaseData/StartState/BAG_nieuwbouw/BAG_RecentsteJaar_pand_toekomst', 'WegVBO_NaRecentJaar_PerDoel');
	}
}