	attribute<Actor/LU_ModelType> LU_ModelType_rel := NVK/LHMType/LU_ModelType_rel[LHMType_rel];
	attribute<String>             NatuurType_code  := substr(code, 0, 3);
	attribute<NatuurType>         NatuurType_rel   := rlookup(NatuurType_code, NatuurType/code);
	
	attribute<bool>               IsKlimaatBos     := NatuurType_rel == NatuurType/v/Bossen_met_productiefunctie;
	
	
	parameter<UInt32> nrAttr := 7;
	container V := for_each_nedv(AsItemName(naam), 'value('+string(id(.))+', ..)', void, .);
	unit<uint8> MNP_Beheertypen := unique_uint8(MNP_BeheertypenKaart_val)
