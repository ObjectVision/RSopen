unit<UInt8> NatuurType : NrOfRows = 18
{
	attribute<String> code: ['N00', 'N01', 'N02', 'N03', 'N04', 'N05', 'N06', 'N07', 'N08', 'N09', 'N10', 'N11', 'N12', 'N13', 'N14', 'N15', 'N16', 'N17'];
	attribute<String> name: ['Nog om te vormen', 'Grootschalige dynamische natuur', 'Rivieren', 'Beken en bronnen', 'Stilstaande wateren', 'Moerassen', 'Voedselarme venen en vochtige heiden', 'Droge heiden', 'Open duinen', 'Schorren of kwelders', 'Vochtige schraallanden', 'Droge schraallanden', 'Rijke graslanden en akkers', 'Vogelgraslanden', 'Vochtige bossen', 'Droge bossen', 'Bossen met productiefunctie', 'Cultuurhistorische bossen'];
	attribute<String> Label := code + ' ' + name;
	
	container V := for_each_nedv(AsItemName(name), 'value('+string(id(.))+', ..)', void, .);
}
