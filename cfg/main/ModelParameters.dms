////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//
// Dit is RSOpen, de open source versie van het model RuimteScanner. Het scipt wordt uitgegeven onder GNU-GPL licentie.
//
// RSOpen is ontwikkeld door PBL Planbureau voor de Leefomgeving, i.s.m Object Vision en VU Vrije Universiteit Amsterdam.
// Opdrachtgever/ontwikkelaar PBL: Bas van Bemmel (Bas.vanBemmel@pbl.nl)
// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Deze file specificeert de ModelParameters: Parameters die voor elk scenario en elke Variant hetzelfde zijn.
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container ModelParameters : using = "Units;Geography;SourceData/RegioIndelingen"
{
	parameter<String>    StudyArea                     := 'Nederland', Descr = "Welk gebied moet het model beslaan. Heel Nederland, of een kleiner studiegebied. Opties: Nederland Friesland Noord_Holland Utrecht. De mogelijke opties zijn gedefinieerd in Geography/StudyAreas. De studiegebied keuze heeft natuurlijk effect op welke cellen er beschouwd worden. Deze waarde wordt ook als suffix in alle ontkoppelde/resultaat bestanden verwerkt."; 
	parameter<Bool>      AlleenEindjaar                := =replace_value(expand(., '%env:AlleenEindjaar%'), 'env:AlleenEindjaar', 'TRUE'), Descr = "Bepaalt of de allocatie in één stap naar het eindjaar springt (TRUE) of via de tussenliggende zichtjaren (2030, 2040, ...) sequentieel doorrekent (FALSE). TRUE:  springt direct van basisjaar naar eindjaar. Tussenliggende zichtjaren verschijnen NIET in de GeoDMS-tree en worden ook niet berekend. De padafhankelijkheid vervalt hierdoor. FALSE: alle zichtjaren worden sequentieel doorlopen. Resultaten van eerder zichtjaren vormen input voor latere (padafhankelijk). Alle zichtjaren zijn zichtbaar in de boom. In batchmodus wordt deze parameter aangestuurd via de omgevingsvariabele AlleenEindjaar. LET OP: de keuze TRUE vs FALSE kan effect hebben op de allocatieresultaten doordat de padafhankelijke verdichtings- en verdringingsmechanismen anders doorwerken.";
	
	// ===== ONTKOPPELINGS­PARAMETERS =====
	// Het model kan in stappen worden uitgevoerd door tussenresultaten weg te schrijven ("ontkoppelen") en bij volgende runs te hergebruiken. Dit bespaart rekentijd tijdens ontwikkeling/debuggen.
	parameter<Bool>      BaseDataOntkoppeld            := TRUE, Descr = "Gebruik maken van reeds berekende en opgeslagen (ontkoppelde) voorbereidende data (pre-allocatie, generiek). Optie: TRUE, FALSE. Deze data is voor alle varianten gelijk, en duurt relatief lang om te berekenen.";
	parameter<Bool>      VariantDataOntkoppeld         := FALSE, Descr = "Gebruik maken van reeds berekende en opgeslagen (ontkoppelde) voorbereidende data (pre-allocatie, Variant-specifiek). Opties: TRUE, FALSE. Dit is handig bij het debuggen/exploreren van allocatie tussenstappen. Deze duren relatief kort om te berekenen, dus kan ook makelijk op FALSE staan.";
	parameter<Bool>      StandAllocatieOntkoppeld      := TRUE, Descr = "Wil je ontkoppelde model (stand) resultaten gebruiken. Handing wanneer je in de GUI de indicatoren wil exploreren.";
	parameter<Bool>      BAG_WP5_rel_Ontkoppeld        := TRUE, Descr = "Voor debug doeleinden; tijdens het debuggen is het onhandig om telkens dit te laten uitrekenen. Normaal kan dit dus op FALSE stsaan. Het wordt overigens in de SD ontkoppeld.";
	parameter<bool>      OntkoppelStedelijkeKlasses    := FALSE, Descr = "Debug: wanneer je alleen Landbouw wilt debuggen en de stedelijke functies exogeen wilt maken. Dan run je een keer de stedelijke functies, daarna zet je deze op TRUE.";
	parameter<bool>      LandUseMapOntkoppeld          := FALSE, Descr = "Zijn de Land-use maps in de indicatoren al ontkoppeld?";

	parameter<YearRange> Model_StartYear               := 2023[YearRange], Descr = "Actueel/recent jaar met dubbele functie: 1) centraal uitgangspunt voor de allocatie; 2) IJkjaar voor dichtheden: de verhouding woningen/banen per hectare in dit jaar. Dient gelijk te zijn aan LISA_StartYear wanneer werken wordt meegealloceerd. Redenen:
																						1) De werkdichtheid (m²PandFootprint/ha) combineert BAG-pandfootprints van dit jaar (noemer) met
																						   LISA-banen van LISA_StartYear (teller). Bij ongelijke jaren is de ratio inconsistent.
																						2) De startstate combineert BAG-woningen/panden (van dit jaar) met LISA-banen (van LISA_StartYear).
																						   Panden gebouwd tussen LISA_StartYear en dit jaar bevatten dan 0 LISA-banen.
																						3) De groeiperiode naar het eerste zichtjaar (2030 - Model_StartYear) veronderstelt dat de
																						   banendata van dit jaar is. Bij oudere LISA-data worden tussenliggende jaren niet gemodelleerd.
																						4) CBS-regioindelingen (gemeentegrenzen) kunnen tussen de twee jaren afwijken door herindeling."
																			, IntegrityCheck = "(!SectorAllocRegio/Uq_Sectors/HasWerkenSector || uint32(This) == LISA_StartYear) && This < 2030[YearRange]"; //check om ervoor te zorgen dat dynamische set van zichtjaren blijft werken /Classifications/Time/ModelJaar
	parameter<YearRange> Model_FinalYear               := 2120[YearRange], Descr = "Laatste jaar waarvoor standgegevens worden berekend in de allocatieprocedure", IntegrityCheck = "This > 2030[YearRange]"; //check om ervoor te zorgen dat dynamische set van zichtjaren blijft werken /Classifications/Time/ModelJaar

	parameter<UInt8>     Default_NrOfIters             := 2b, Descr = "Aantal iteraties in de allocatie. Iteraties zijn  nodig om niet vervulde restclaims in een iteratie in een volgende iteratie te vervullen";
	parameter<UInt8>     Default_NrOfSequences         := 2b, Descr = "Aantal sequences in de allocatie. Sequences zijn nodig om verdrongen wooneenheden, banen etc in een sequentie in een volgende sequentie te heralloceren, voor zover de verdringing restclaims opleverede. Dit moet minimaal 2 zijn.", IntegrityCheck = "This >= 2b"; 

	// Jaren/Data waarvoor recente waarnemingen beschikbaar zijn. t.b.v. het inlezen ervan.
	parameter<UInt32>    BAG_RecentYear                :=  2026, Descr = "Wat is het meest recent beschikbare jaar van de BAG";
	parameter<String>    BAG_file_date                 := '20260108', Descr = "Welke bestandsdatum van BAG moet worden gebruikt";
	parameter<UInt32>    LISA_FileYear                 :=  2023, Descr = "Wat is het bestandsjaar van de LISA dataset";
	parameter<UInt32>    LISA_StartYear                :=  2023, Descr = "Welk jaar van LISA moet worden gebruikt", IntegrityCheck = "LISA_StartYear <= LISA_FileYear"; //evident dat lisa startjaar kleiner over gelijk moet zijn aan het filejaar. Het zijn immers geen prognses.
	parameter<String>    BBG_Year                      := '2022', Descr = "Welk jaar van BBG moet worden gebruikt";
	parameter<String>    BBG_Verblijfsrecreatie_Year   := '2022', Descr = "Om Verblijfsrecreatie trends te bepalen moet een BBG jaar gekozen worden.";
	parameter<String>    BGT_file_date                 := '20251117', Descr = "Welke bestandsdatum van de Basisregistratie Grootschalige Topografie moet worden gebruikt"; 
	parameter<String>    BRT_file_date                 := '20250318', Descr = "Welke bestandsdatum van de Basisregistratie Topografie moet worden gebruikt";
	parameter<String>    IBIS_Year                     := '2023', Descr = "Welk jaar van IBIS moet worden gebruikt";
	parameter<String>    NVM_filedate                  := '20251024', Descr = "Welke bestandsdatum van de NVM-coefficienen moet worden gebruikt";
	parameter<String>    NVM_coeff_Year                := '2023', Descr = "Welk jaar moet als prijsniveau worden gehanteerd uit de hedonische prijsanalyse";
	parameter<String>    Verblijfsrec_coeff_date       := '20211213', Descr = "Welke bestandsdatum van de Verblijfsrecreatie coëfficiënten moet worden gebruikt, tbv suitability";
	parameter<String>    Werken_coeff_date             := '20220401', Descr = "Welke bestandsdatum van de Werken coëfficiënten moet worden gebruikt, tbv suitability";
	parameter<String>    NWB_file_date                 := '20211001', Descr = "Welke bestandsdatum van het Nationaal Wegenbestand moet worden gebruikt";
	parameter<String>    LGN_Year                      := '2022', Descr = "Welke bestandsdatum van het Landelijk Grondgebruiksbestand Nederland moet worden gebruikt";
	parameter<String>    TIGRIS_filedate               := '20241223_Run29_correctie_Grensfix', Descr = "Welke versie van de TIGRIS-claims moet worden gebruikt (relevant voor wonen/werken)"; 
	parameter<String>    Restricties_filedate          := '2026-03-10_18-02-04', Descr = "Welke bestandsdatum van de Ruimtelijke Restricities moet worden gebruikt";
	parameter<String>    Stimuli_filedate              := '2026-03-10_18-02-04', Descr = "Welke bestandsdatum van de Stimuli moet worden gebruikt";
	parameter<String>    PlanCapaciteit_filedate       := '2025-11-20_15-23-29', Descr = "Welke bestandsdatum van de Plan Capaciteiten moet worden gebruikt";
	parameter<Bool>      UsePrivPlanCapaciteit         := TRUE, Descr = "Er zijn publiek en niet-publiek beschikbare plancapaciteiten. Wil je die niet-publieke gebruiken?";
	
	#include<Wonen.dms>
	#include<Werken.dms>
	#include<Verblijfsrecreatie.dms>
	#include<Zon.dms>
	#include<Wind.dms>
	#include<Landbouw.dms>
	#include<Advanced.dms>
	
	// ===== ALLOCATIEVOLGORDE (SectorAllocRegio/Elements/Text) =====
	// Deze tabel definieert de volgorde waarin sectoren worden gealloceerd en op welk regionaal
	// schaalniveau. Elke rij bevat 5 kolommen (zie nrAttr):
	//
	//   1. name             : Sectornaam (moet overeenkomen met Classifications/Actor/Sector)
	//   2. AllocRegio       : Regionaal schaalniveau waarop claims worden verdeeld
	//                         (NVM, COROP, Provincie, NL).
	//   3. UseInLaterSeq    : TRUE = deze sector kan worden verdrongen door latere sectoren en wordt
	//                         daarom in opvolgende sequenties opnieuw doorlopen om verdrongen eenheden
	//                         te heralloceren. FALSE = eenmalige allocatie, geen herberekening bij verdringing.
	//                         Alleen de kleinste regio per sector krijgt TRUE (verdringing zo lokaal mogelijk).
	//   4. AantalIters      : Aantal iteraties in de eerste sequentie (Default_NrOfIters of specifiek).
	//   5. AantalItersInLaterSeq : Aantal iteraties in eventuele vervolgsequenties.
	//
	// VOLGORDE IS BELANGRIJK: sectoren worden van boven naar beneden gealloceerd.
	// Gelijke sectornamen (bijv. Wonen op NVM, daarna Wonen op Provincie) worden na elkaar doorlopen:
	// eerst de fijnste regio, dan grovere regio's om restclaims op te vangen.
	// Uitgecommentarieerde regels (bijv. COROP, Landbouw) zijn beschikbaar maar momenteel niet actief.	
	
	unit<UInt8> SectorAllocRegio := range(uint8, 0b, 4b) // e.g. 7 = het huidige aantal SectorAllocRegio-combinaties in Elements/Text hieronder. Pas dit aan als je regels toevoegt/verwijdert.
	, Descr = "Volgorde waarin de sectoren gealloceerd worden, incluisef het schaalniveau waarop dit (achtereenvolgens) gebeurt (de AllocRegio's)."
	, using = "/Classifications;/Classifications/actor;/Classifications/Modellering"
	{
		unit<Uint32> Elements := Range(uint32, 0, nrAttr * #.) 
		, Descr = "Gelijke sectoren moeten direct na elkaar komen. van klein naar grote alloc regios. Teneinde verdringing zo lokaal mogelijk op te lossen. Anders kan wel, maar geeft wellicht onwenselijke resultaten."
		{
			attribute<String> Text: [
			// name                , AllocRegio            , UseInLaterSeq , AantalIters        , AantalItersInLaterSeq
			  'Wonen'              , 'NVM'                 ,  'TRUE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 // ,'Wonen'              , 'COROP'               , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 // ,'Wonen'              , 'Provincie'           , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 ,'Werken'             , 'NVM'                 ,  'TRUE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 // ,'Werken'             , 'COROP'               , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 // ,'Werken'             , 'Provincie'           , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 ,'Verblijfsrecreatie' , 'Provincie'           ,  'TRUE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			//  ,'Zon'                , 'Provincie'           ,  'TRUE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			//  ,'Wind'               , 'Provincie'           ,  'TRUE'       ,'NrOfIters_Wind'    ,'NrOfIters_Wind'
			 //,'Wind'               , 'NL'                  , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			 ,'Landbouw'           , 'Provincie'           , 'FALSE'       ,'Default_NrOfIters' ,'Default_NrOfIters'
			];
		}
		
		attribute<String>       Default_Sectorname    := Elements/Text[value(uint32(id(.))* nrAttr + 0, Elements)];
		attribute<Sector>       Default_Sector        := ='union_data(.,'+asList('Sector/V/'+Default_Sectorname, ',')+')', Descr = "relatie naar Sector";
		// attribute<String>     Default_Regioname     := replace(Elements/Text[value(uint32(id(.))* nrAttr + 1, Elements)], 'Rec_AllocRegio_name', Recreatie_AllocRegio_name);
		attribute<String>       Default_Regioname     := Elements/Text[value(uint32(id(.))* nrAttr + 1, Elements)];
		attribute<AllocRegiosK> Default_Regio         := ='union_data(.,'+asList('AllocRegiosK/V/'+Default_Regioname, ',')+')', Descr = "relatie naar AllocRegio";
		
		parameter<String>       Recreatie_AllocRegio_name := rjoin('Verblijfsrecreatie', Default_Sectorname, Default_Regioname);
		// Kan een sector verdrongen worden door daarop volgende sectoren? In dat geval moet deze sector in een volgende sequence opnieuw worden doorlopen. In dat geval moet deze sector TRUE krijgen.
		// Verdringing wordt vervolgens zo lokaal mogelijk opgelost, en dus krijgt de kleinste regio per sector een TRUE.
		attribute<Bool>         UseInLaterSequences     := Elements/Text[value(uint32(id(.))* nrAttr + 2, Elements)][bool]; 
		attribute<UInt8>        AantalIters             := uint8(replace(Elements/Text[value(uint32(id(.))* nrAttr + 3, Elements)], 'Default_NrOfIters', string(ModelParameters/Default_NrOfIters), 'NrOfIters_Wind', string(ModelParameters/Wind/NrOfIters_Wind))), Descr = "Hier wordt het aantal iteraties uit de ModelParameters opgehaald en in deze lijst toegevoegd.";
		attribute<UInt8>        AantalItersInLaterSeq   := uint8(replace(Elements/Text[value(uint32(id(.))* nrAttr + 4, Elements)], 'Default_NrOfIters', string(ModelParameters/Default_NrOfIters), 'NrOfIters_Wind', string(ModelParameters/Wind/NrOfIters_Wind))), Descr = "Er kan eventueel voor worden gekozen in latere sequenties minder iteraties te gebruiken. Dat kan hier insteld worden.";
		attribute<String>       SortOrder               := string(rlookup(Default_Sectorname, Default_Sectorname)), Descr = "foolproof oplossing om een sortorder af te dwingen, die gebruikt wordt bij de sortering van Uq_Sectors";

		attribute<AllocRegiosK> AllocRegio_rel          := Default_Regio;
		attribute<Sector>       Sector_rel              := Default_Sector;
		
		attribute<String>       name                    := AllocRegio_name +'_'+ Sector_name;
		attribute<String>       SectorAllocRegio_name   := Sector_name +'_'+ AllocRegio_name;
		attribute<String>       Sector_name             := Sector/name[Sector_rel];
		attribute<String>       AllocRegio_name         := AllocRegiosK/name[AllocRegio_rel];
		attribute<String>       AllocRegio_path         := AllocRegiosK/path[AllocRegio_rel];
		
		attribute<Bool>         IsFirstSectorAllocRegio := id(.) == 0b;
		attribute<String>       PrevName                := IsFirstSectorAllocRegio ? '' : name[id(.) - min_elem( id(.), 1b)];
		attribute<String>       PrevState               := IsFirstSectorAllocRegio ? 'StateVoorAllocatie' : PrevName+'/StateNaAllocatie';
		attribute<String>       Subsector_ref           := Sector/Subsector_ref[Sector_rel];
		
		unit<UInt8>             WonenAllocRegio := select_with_org_rel(Sector_rel == Sector/V/Wonen);
		
		unit<UInt8> Uq_AllocRegios := unique(AllocRegio_name)
		, Descr = "Unieke lijst van AllocRegio's die in deze variant gebruikt worden. Nodig om bijvoorbeeld voor alle gebruikte allocregio's iets uit te rekenen."
		{
			attribute<String> AllocRegio_name := values;
			attribute<String> AllocRegio_path := rjoin(lowercase(AllocRegio_name), lowercase(../AllocRegio_name), ../AllocRegio_path);
		}
		unit<UInt8> Uq_Sectors := unique(SortOrder + Default_Sectorname)
		, Descr = "SortOrder wordt hier voorgezet om ervoor te zorgen dat dit niet alfabetisch wordt gesorteerd.
					Dit wordt gebruikt om in if-statements te kijken of bepaalde sectoren wel of niet gealloceerd worden."
		{
			attribute<String> Sectorname                  := substr(values, 1, 99);
			attribute<Bool>   IsWonen                     := lowercase(Sectorname) == lowercase('Wonen');
			attribute<Bool>   IsWerken                    := lowercase(Sectorname) == lowercase('Werken');
			attribute<Bool>   IsVerblijfsrecreatie        := lowercase(Sectorname) == lowercase('Verblijfsrecreatie');
			attribute<Bool>   IsZon                       := lowercase(Sectorname) == lowercase('Zon');
			attribute<Bool>   IsWind                      := lowercase(Sectorname) == lowercase('Wind');
			attribute<Bool>   IsLandbouw                  := lowercase(Sectorname) == lowercase('Landbouw');
			parameter<Bool>   HasWonenSector              := any(IsWonen);
			parameter<Bool>   HasWerkenSector             := any(IsWerken);
			parameter<Bool>   HasVerblijfsrecreatieSector := any(IsVerblijfsrecreatie);
			parameter<Bool>   HasZonSector                := any(IsZon);
			parameter<Bool>   HasWindSector               := any(IsWind);
			parameter<Bool>   HasLandbouwSector           := any(IsLandbouw);
			
			unit<UInt8> wo_Landbouw := select_with_attr_by_cond(., NOT(IsLandbouw));
		}
		
		unit<UInt8> SectorAllocRegio_LaterSeq := select_with_org_rel(SectorAllocRegio/UseInLaterSequences)
		{
			attribute<String>       name                  := ../name[org_rel];
			attribute<Sector>       Sector_rel            := ../Sector_rel[org_rel];
			attribute<UInt8>        AantalIters           := ../AantalIters[org_rel];
			attribute<UInt8>        AantalItersInLaterSeq := ../AantalItersInLaterSeq[org_rel];
			attribute<AllocRegiosK> AllocRegio_rel        := ../AllocRegio_rel[org_rel];
			attribute<String>       Label                 := ../Label[org_rel];
			attribute<String>       Sector_name           := ../Sector_name[org_rel];
			attribute<String>       AllocRegio_name       := ../AllocRegio_name[org_rel];
			attribute<String>       AllocRegio_path       := ../AllocRegio_path[org_rel];
			attribute<String>       SrcRefRestricties     := ../SrcRefRestricties[org_rel];
			attribute<String>       Subsector_ref         := ../Subsector_ref[org_rel];
		
			attribute<Bool>   IsFirstSectorAllocRegio := id(.) == 0b;
			attribute<String> PrevName                := IsFirstSectorAllocRegio ? '' : name[id(.) - min_elem( id(.), 1b)];
			attribute<String> PrevState               := IsFirstSectorAllocRegio ? 'StateVoorAllocatie' : PrevName+'/StateNaAllocatie';
			
			
			parameter<String> LastSectorBeforeWind     := LastInSector[Sector/V/Wind - 1[Sector]];
			attribute<String> LastInSector    (Sector) := last(name, Sector_rel);
			attribute<String> Sector_PrevName (Sector) := Sector/name[id(Sector)- 1[Sector]];
			
			container V := for_each_nedv(name, string(id(.))+'[..]', void, .);
		}
		parameter<UInt32> nrAttr := 5, Descr ="Aantal kolommen per rij in Elements/Text: name, AllocRegio, UseInLaterSeq, AantalIters, AantalItersInLaterSeq. Wordt gebruikt om de Text-array te indexeren (id * nrAttr + kolomnr).";
	}
}