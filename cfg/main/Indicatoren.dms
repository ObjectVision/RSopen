//
// Deze file specificeert de indicatoren die kunnen worden opgevraagd o.b.v.: 1) (waargenomen) standgegevens in het basisjaar; 2) berekende allocatieresultaten, per zichjtjaar
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container Indicatoren :=
	for_each_ne(
		Classifications/Modellering/AllCases/Label
		, 'Indicatoren_T('+string(id(Classifications/Modellering/AllCases))+')'
	);
	
Template Indicatoren_T
:	using = "Units;Geography;Classifications"
{
	parameter<Modellering/AllCases>       Case_id;
	///
	parameter<Modellering/ScenarioK>      Scenario_rel := Modellering/AllCases/scenario_rel[case_id];
	parameter<VariantParameters/VariantK> Variant_rel  := Modellering/AllCases/Variant_rel[case_id];
	
	parameter<string> Scenario_name := Modellering/ScenarioK/name[Scenario_rel];
	parameter<string> Variant_name  := VariantParameters/VariantK/name[Variant_rel];
	parameter<string> Casus_name    := Modellering/AllCases/label[Case_id];
	
	container ThisCasus                  := .;
	container ThisVariantData            := ='VariantData/'+Variant_name;
	container ThisVariantAllocatie       := ='Allocatie/'+Casus_name;
	container ThisVariantClassifications := ='CaseClassifications/'+Variant_name;
	
	container Zichtjaren :=
		for_each_ne(
			Classifications/Time/Zichtjaar/name
			,	'Templates/Indicatoren/Indicatoren_T('+
					quote(Classifications/Time/Zichtjaar/name)+
				','+Classifications/Time/Zichtjaar/PrevName_triv+
				')'
		)
		,	using = "Units;Geography;Classifications"
	{
		container NPV_agrarisch_landgebruik
		{
			attribute<EUR> Result (AdminDomain) := for_each_nedv(Classifications/Actor/LandbouwKlasses/name, '', AdminDomain, EUR);
		}
		
		#include<Basisjaar.dms>
		#include<BAGSloopNieuwbouwWonen.dms>
		#include<StartState_metBAGSloopNieuwbouwWonen.dms>
		#include<Export.dms>
	}
}