// Contactpersoon/ontwikkelaar Object Vision: Jip Claassens (jclaassens@objectvision.nl)
// Contactpersoon/ontwikkelaar Deltares: Bart Rijken (bart.rijken@deltares.nl)
//
// Deze file specificeert:
// - het te evalueren (omgevings)scenario, de (beleids)Variant en daarmee de casus (= combinatie van scenario en Variant);
// - De ruimtelijke resolutie waarop wordt gerekend
// - de dms files die nodig zijn om betreffende caus te evalueren (met 'includes') 
//
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

container RSopen_NL2120 : IntegrityCheck = "=GeoDMSVersion() >= 17.0904 ? 'TRUE' : 'Deze_error_geeft_aan_dat_je_een_nieuwere_GeoDMS_versie_moet_gebruiken'" //vanwege geos operatoren, phasecontainer, 
{
	parameter<string> Boervariant_name        := replace_value(expand(., '%env:RSO_BOERVARIANT_NAME%')       , 'env:RSO_BOERVARIANT_NAME'       , 'RationeleBoer'); // RationeleBoer, IntermediateBoer, ConservatieveBoer
	parameter<string> BeregeningScenario_name := replace_value(expand(., '%env:RSO_BEREGENINGSCENARIO_NAME%'), 'env:RSO_BEREGENINGSCENARIO_NAME', 'B1_Beregening_allepercelen_ongelim'); // 'A_GeenBeregening','B1_Beregening_allepercelen_ongelim','B2_Beregening_percelenmetinstal_ongelim'
	
	#include <Units.dms>
	#include <Geography.dms>
	
	#include <ModelParameters.dms>
	#include <VariantParameters.dms>
	
	#include <Classifications.dms>
	container CaseClassifications := 
		for_each_ne(
			VariantParameters/VariantK/name
			,'Templates/CaseClassifications_T('+string(id(VariantParameters/VariantK))+'[uint8])'
		);
	
	#include <PrivData.dms>
	#include <SourceData.dms>
	#include <BaseData.dms>
	
	#include <VariantData.dms>
	#include <Allocatie.dms>

	#include <Indicatoren.dms>
	#include <PostAllocAnalyses.dms>
	
	#include <Templates.dms>
	
	container CommitChecks: Descr = "Verzameling van evaluatie-triggers die de volledige berekeningsketen afdwingen via ExplicitSuppliers.
										Elke parameter evalueert pas naar 'Ready' nadat alle genoemde ExplicitSuppliers succesvol zijn berekend.
										Dit mechanisme wordt gebruikt om snel te kunnen kijken of het model nog werkt alvorens wijzigingen te committen.
										Niet geschikt voor productieruns."
	{
		parameter<string> MaakBaseData1               := 'Ready', ExplicitSuppliers = "/WriteBaseData/Generate_Run1";
		parameter<string> MaakBaseData2               := 'Ready', ExplicitSuppliers = "/WriteBaseData/Generate_Run2";
		parameter<string> MaakVariantData             := 'Ready', ExplicitSuppliers = "=AsList('WriteVariantData/per_Variant/'+VariantParameters/VariantK/name+'/Generate_Run1',';')";
		parameter<string> MaakAllocatieFirstZichtjaar := 'Ready', ExplicitSuppliers = "=AsList('Allocatie/'+Classifications/Modellering/AllCases/Label+'/Zichtjaren/'+first(Classifications/Time/Zichtjaar/name)+'/Impl/Generate',';')";
		
		parameter<string> ClaimRealisatie_Prov_Min    := 'Ready', ExplicitSuppliers = "=AsList('/Indicatoren/'+first(Classifications/Modellering/AllCases/Label)+'/Zichtjaren/'+first(Classifications/Time/Zichtjaar/name)+'/ClaimRealisatie/Per_AllocRegio/Provincie/MinClaim_realisatie/'+CaseClassifications/BAU/StandVar/Claims_sub/name, ';')";
		parameter<string> ClaimRealisatie_Prov_Max    := 'Ready', ExplicitSuppliers = "=AsList('/Indicatoren/'+first(Classifications/Modellering/AllCases/Label)+'/Zichtjaren/'+first(Classifications/Time/Zichtjaar/name)+'/ClaimRealisatie/Per_AllocRegio/Provincie/MaxClaim_realisatie/'+CaseClassifications/BAU/StandVar/Claims_sub/name, ';')";
		parameter<string> ClaimRealisatie_Prov        := 'Ready', ExplicitSuppliers = "=AsList('/Indicatoren/'+first(Classifications/Modellering/AllCases/Label)+'/Zichtjaren/'+first(Classifications/Time/Zichtjaar/name)+'/ClaimRealisatie/Per_AllocRegio/Provincie/Claim_realisatie/all', ';')";
	}
	
	// Settings
	#include <ConfigSettings.dms>
	#include <ExportSettings.dms>
	
	// For debug purposes
	container Desktops 
	{
		container x;
	}
	
	#include <WritePrivData.dms>
	#include <WriteBaseData.dms>
	#include <WriteVariantData.dms>
	container WriteAllocatie
	: Descr = "Debug folder, om snel toegang te hebben tot generate van allocatie resultaten per zichtjaar. Deze lijst is incompleet en volgt vooral gebruikt om snel te testen of het model nog werkt."
	{
		// parameter<string> Write_2030 := /Allocatie/Zichtjaren/Y2030/impl/Generate;
		// parameter<string> Write_2040 := /Allocatie/Zichtjaren/Y2040/impl/Generate;
		parameter<string> Write_2050 := /Allocatie/WLO_hoog_BAU/Zichtjaren/Y2050/impl/Generate;
	}
}